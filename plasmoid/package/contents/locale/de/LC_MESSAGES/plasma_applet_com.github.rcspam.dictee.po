msgid "Polling interval (ms):"
msgstr "Abfrageintervall (ms):"

#: plasmoid/package/contents/ui/configGeneral.qml:207
msgid "How often the widget checks if the daemon is running (in milliseconds)."
msgstr "Wie oft das Widget prüft, ob der Daemon läuft (in Millisekunden)."

#: plasmoid/package/contents/ui/configGeneral.qml:212
msgid "Show last transcription:"
msgstr "Letzte Transkription anzeigen:"

#: plasmoid/package/contents/ui/configGeneral.qml:218
msgid "Display the last transcribed text in the popup window."
msgstr "Den zuletzt transkribierten Text im Popup-Fenster anzeigen."

