#: ui/configGeneral.qml
msgid "General"
msgstr "Allgemein"

#: ui/configGeneral.qml
msgid "Polling interval (ms):"
msgstr "Abfrageintervall (ms):"

#: ui/configGeneral.qml
msgid "How often the widget checks if the daemon is running (in milliseconds)."
msgstr "Wie oft das Widget prüft, ob der Daemon läuft (in Millisekunden)."

#: ui/configGeneral.qml
msgid "Show last transcription:"
msgstr "Letzte Transkription anzeigen:"

#: ui/configGeneral.qml
msgid "Display the last transcribed text in the popup window."
msgstr "Den zuletzt transkribierten Text im Popup-Fenster anzeigen."

#: ui/configGeneral.qml
msgid "Preview mode (test with mic):"
msgstr "Vorschaumodus (Test mit Mikrofon):"

#: ui/configGeneral.qml
msgid "Microphone volume:"
msgstr "Mikrofonlautstärke:"

#: ui/configGeneral.qml
msgid "Adjust the microphone input volume (PipeWire/PulseAudio default source)."
msgstr "Eingangslautstärke des Mikrofons anpassen (PipeWire/PulseAudio Standardquelle)."

#: ui/configGeneral.qml
msgid "Noise floor:"
msgstr "Grundrauschen:"

#: ui/configGeneral.qml
msgid "Calibrate"
msgstr "Kalibrieren"

#: ui/configGeneral.qml
msgid "Calibration done!"
msgstr "Kalibrierung abgeschlossen!"

#: ui/configGeneral.qml
msgid "Calibration failed"
msgstr "Kalibrierung fehlgeschlagen"

#: ui/configGeneral.qml
msgid "Record 5 seconds of silence to calibrate the background noise level. This improves animation accuracy."
msgstr "5 Sekunden Stille aufnehmen, um den Hintergrundgeräuschpegel zu kalibrieren. Dies verbessert die Animationsgenauigkeit."

#: ui/configGeneral.qml
msgid "Noise gate:"
msgstr "Noise Gate:"

#: ui/configGeneral.qml
msgid "Audio levels below this threshold are zeroed. Increase to suppress background noise and get clean silence."
msgstr "Audiopegel unterhalb dieser Schwelle werden auf Null gesetzt. Erhöhen, um Hintergrundgeräusche zu unterdrücken und saubere Stille zu erhalten."

#: ui/configGeneral.qml
msgid "Envelope shape:"
msgstr "Hüllkurvenform:"

#: ui/configGeneral.qml
msgid "Flat"
msgstr "Flach"

#: ui/configGeneral.qml
msgid "Normal"
msgstr "Normal"

#: ui/configGeneral.qml
msgid "Controls the Hanning envelope shape. 0 = flat (uniform bars), 1 = normal, higher = more peaked at the center."
msgstr "Steuert die Hanning-Hüllkurvenform. 0 = flach (gleichmäßige Balken), 1 = normal, höher = stärker zentriert."

#: ui/configGeneral.qml
msgid "Envelope center:"
msgstr "Hüllkurvenzentrum:"

#: ui/configGeneral.qml
msgid "Shift the envelope peak across the frequency range (80–4000 Hz). Useful with rainbow colors to emphasize different frequency bands."
msgstr "Den Hüllkurvenpeak über den Frequenzbereich verschieben (80–4000 Hz). Nützlich mit Regenbogenfarben, um verschiedene Frequenzbänder hervorzuheben."

