#: ui/FullRepresentation.qml
msgid "Daemon stopped"
msgstr "Daemon arrêté"

#: ui/FullRepresentation.qml
msgid "Daemon active"
msgstr "Daemon actif"

#: ui/FullRepresentation.qml
msgid "Recording…"
msgstr "Enregistrement…"

#: ui/FullRepresentation.qml
msgid "Transcribing…"
msgstr "Transcription…"

#: ui/FullRepresentation.qml
msgid "Start daemon"
msgstr "Démarrer le daemon"

#: ui/FullRepresentation.qml
msgid "Stop daemon"
msgstr "Arrêter le daemon"

#: ui/FullRepresentation.qml
msgid "Voice dictation"
msgstr "Dictée vocale"

#: ui/FullRepresentation.qml
msgid "Dictation + Translation"
msgstr "Dictée + Traduction"

#: ui/FullRepresentation.qml
msgid "Cancel recording"
msgstr "Annuler l'enregistrement"

#: ui/FullRepresentation.qml
msgid "Last transcription:"
msgstr "Dernière transcription :"

#: ui/FullRepresentation.qml
msgid "Preview (mic test)"
msgstr "Aperçu (test micro)"

#: ui/FullRepresentation.qml
msgid "Configure Dictée"
msgstr "Configurer Dictée"

#: ui/FullRepresentation.qml
msgid "Pin popup"
msgstr "Épingler la popup"

#: ui/FullRepresentation.qml
msgid "Unpin popup"
msgstr "Désépingler la popup"

#: ui/FullRepresentation.qml
msgid "Recording silence…"
msgstr "Enregistrement du silence…"

#: ui/configGeneral.qml
msgid "General"
msgstr "Général"

#: ui/configGeneral.qml
msgid "Polling interval (ms):"
msgstr "Intervalle de polling (ms) :"

#: ui/configGeneral.qml
msgid "How often the widget checks if the daemon is running (in milliseconds)."
msgstr "Fréquence à laquelle le widget vérifie si le daemon est actif (en millisecondes)."

#: ui/configGeneral.qml
msgid "Show last transcription:"
msgstr "Afficher la dernière transcription :"

#: ui/configGeneral.qml
msgid "Display the last transcribed text in the popup window."
msgstr "Afficher le dernier texte transcrit dans la fenêtre popup."

#: ui/configGeneral.qml
msgid "Preview mode (test with mic):"
msgstr "Mode aperçu (test avec micro) :"

#: ui/configGeneral.qml
msgid "Microphone volume:"
msgstr "Volume du microphone :"

#: ui/configGeneral.qml
msgid "Adjust the microphone input volume (PipeWire/PulseAudio default source)."
msgstr "Ajuster le volume d'entrée du microphone (source par défaut PipeWire/PulseAudio)."

#: ui/configGeneral.qml
msgid "Noise floor:"
msgstr "Plancher de bruit :"

#: ui/configGeneral.qml
msgid "Calibrate"
msgstr "Calibrer"

#: ui/configGeneral.qml
msgid "Calibration done!"
msgstr "Calibration terminée !"

#: ui/configGeneral.qml
msgid "Calibration failed"
msgstr "Échec de la calibration"

#: ui/configGeneral.qml
msgid "Record 5 seconds of silence to calibrate the background noise level. This improves animation accuracy."
msgstr "Enregistrer 5 secondes de silence pour calibrer le niveau de bruit ambiant. Cela améliore la précision de l'animation."

#: ui/configGeneral.qml
msgid "Noise gate:"
msgstr "Noise gate :"

#: ui/configGeneral.qml
msgid "Audio levels below this threshold are zeroed. Increase to suppress background noise and get clean silence."
msgstr "Les niveaux audio en dessous de ce seuil sont mis à zéro. Augmentez pour supprimer le bruit de fond et obtenir un silence propre."

#: ui/configGeneral.qml
msgid "Envelope shape:"
msgstr "Forme de l'enveloppe :"

#: ui/configGeneral.qml
msgid "Flat"
msgstr "Plat"

#: ui/configGeneral.qml
msgid "Normal"
msgstr "Normal"

#: ui/configGeneral.qml
msgid "Controls the Hanning envelope shape. 0 = flat (uniform bars), 1 = normal, higher = more peaked at the center."
msgstr "Contrôle la forme de l'enveloppe de Hanning. 0 = plat (barres uniformes), 1 = normal, plus élevé = plus pointu au centre."

#: ui/configGeneral.qml
msgid "Envelope center:"
msgstr "Centre de l'enveloppe :"

#: ui/configGeneral.qml
msgid "Shift the envelope peak across the frequency range (80–4000 Hz). Useful with rainbow colors to emphasize different frequency bands."
msgstr "Déplacer le pic de l'enveloppe sur la plage de fréquences (80–4000 Hz). Utile avec les couleurs arc-en-ciel pour accentuer différentes bandes de fréquences."

