msgstr "Espacement des barres (px) :"

#: ui/configGeneral.qml
msgid "Bar corner radius:"
msgstr "Rayon des coins des barres :"

#: ui/configGeneral.qml
msgid "Min height (%):"
msgstr "Hauteur minimale (%) :"

#: ui/configGeneral.qml
msgid "Idle breathing animation:"
msgstr "Animation de respiration au repos :"

#: ui/configGeneral.qml
msgid "Animation speed (ms):"
msgstr "Vitesse d'animation (ms) :"

#: ui/configGeneral.qml
msgid "Wave settings"
msgstr "Paramètres de l'onde"

#: ui/configGeneral.qml
msgid "Width (px):"
msgstr "Largeur (px) :"

#: ui/configGeneral.qml
msgid "Line thickness (px):"
msgstr "Épaisseur du trait (px) :"

#: ui/configGeneral.qml
msgid "Wave frequency:"
msgstr "Fréquence de l'onde :"

#: ui/configGeneral.qml
msgid "Amplitude (%):"
msgstr "Amplitude (%) :"

#: ui/configGeneral.qml
