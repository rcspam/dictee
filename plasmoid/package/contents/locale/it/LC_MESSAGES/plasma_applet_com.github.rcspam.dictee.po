msgstr "Anteprima (test microfono)"

#: ui/FullRepresentation.qml
msgid "Configure Dictée"
msgstr "Configura Dictée"

#: ui/FullRepresentation.qml
msgid "Pin popup"
msgstr "Fissa popup"

