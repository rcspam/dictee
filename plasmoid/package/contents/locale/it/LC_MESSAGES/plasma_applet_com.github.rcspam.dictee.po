#: ui/configGeneral.qml
msgid "General"
msgstr "Generale"

#: ui/configGeneral.qml
msgid "Polling interval (ms):"
msgstr "Intervallo di polling (ms):"

#: ui/configGeneral.qml
msgid "How often the widget checks if the daemon is running (in milliseconds)."
msgstr "Ogni quanto il widget verifica se il daemon è in esecuzione (in millisecondi)."

#: ui/configGeneral.qml
msgid "Show last transcription:"
msgstr "Mostra ultima trascrizione:"

#: ui/configGeneral.qml
msgid "Display the last transcribed text in the popup window."
msgstr "Visualizza l'ultimo testo trascritto nella finestra popup."

#: ui/configGeneral.qml
msgid "Preview mode (test with mic):"
msgstr "Modalità anteprima (test con microfono):"

#: ui/configGeneral.qml
msgid "Microphone volume:"
msgstr "Volume del microfono:"

#: ui/configGeneral.qml
msgid "Adjust the microphone input volume (PipeWire/PulseAudio default source)."
msgstr "Regola il volume di ingresso del microfono (sorgente predefinita PipeWire/PulseAudio)."

#: ui/configGeneral.qml
msgid "Noise floor:"
msgstr "Rumore di fondo:"

#: ui/configGeneral.qml
msgid "Calibrate"
msgstr "Calibra"

#: ui/configGeneral.qml
msgid "Calibration done!"
msgstr "Calibrazione completata!"

#: ui/configGeneral.qml
msgid "Calibration failed"
msgstr "Calibrazione fallita"

#: ui/configGeneral.qml
msgid "Record 5 seconds of silence to calibrate the background noise level. This improves animation accuracy."
msgstr "Registra 5 secondi di silenzio per calibrare il livello di rumore di fondo. Questo migliora la precisione dell'animazione."

#: ui/configGeneral.qml
msgid "Noise gate:"
msgstr "Noise gate:"

#: ui/configGeneral.qml
msgid "Audio levels below this threshold are zeroed. Increase to suppress background noise and get clean silence."
msgstr "I livelli audio sotto questa soglia vengono azzerati. Aumentare per sopprimere il rumore di fondo e ottenere un silenzio pulito."

#: ui/configGeneral.qml
msgid "Envelope shape:"
msgstr "Forma dell'inviluppo:"

#: ui/configGeneral.qml
msgid "Flat"
msgstr "Piatto"

#: ui/configGeneral.qml
msgid "Normal"
msgstr "Normale"

#: ui/configGeneral.qml
msgid "Controls the Hanning envelope shape. 0 = flat (uniform bars), 1 = normal, higher = more peaked at the center."
msgstr "Controlla la forma dell'inviluppo di Hanning. 0 = piatto (barre uniformi), 1 = normale, più alto = più appuntito al centro."

#: ui/configGeneral.qml
msgid "Envelope center:"
msgstr "Centro dell'inviluppo:"

#: ui/configGeneral.qml
msgid "Shift the envelope peak across the frequency range (80–4000 Hz). Useful with rainbow colors to emphasize different frequency bands."
msgstr "Spostare il picco dell'inviluppo nell'intervallo di frequenze (80–4000 Hz). Utile con i colori arcobaleno per evidenziare diverse bande di frequenza."

