#: ui/FullRepresentation.qml
msgid "Daemon stopped"
msgstr "Daemon зупинено"

#: ui/FullRepresentation.qml
msgid "Daemon active"
msgstr "Daemon активний"

#: ui/FullRepresentation.qml
msgid "Recording…"
msgstr "Запис…"

#: ui/FullRepresentation.qml
msgid "Transcribing…"
msgstr "Транскрипція…"

#: ui/FullRepresentation.qml
msgid "Start daemon"
msgstr "Запустити daemon"

#: ui/FullRepresentation.qml
msgid "Stop daemon"
msgstr "Зупинити daemon"

#: ui/FullRepresentation.qml
msgid "Voice dictation"
msgstr "Голосовий диктант"

#: ui/FullRepresentation.qml
msgid "Dictation + Translation"
msgstr "Диктант + Переклад"

#: ui/FullRepresentation.qml
msgid "Cancel recording"
msgstr "Скасувати запис"

#: ui/FullRepresentation.qml
msgid "Last transcription:"
msgstr "Остання транскрипція:"

#: ui/FullRepresentation.qml
msgid "Preview (mic test)"
msgstr "Попередній перегляд (тест мікрофона)"

#: ui/FullRepresentation.qml
msgid "Configure Dictée"
msgstr "Налаштувати Dictée"

#: ui/FullRepresentation.qml
msgid "Pin popup"
msgstr "Закріпити спливаюче вікно"

#: ui/FullRepresentation.qml
msgid "Unpin popup"
msgstr "Відкріпити спливаюче вікно"

#: ui/FullRepresentation.qml
msgid "Recording silence…"
msgstr "Запис тиші…"

#: ui/configGeneral.qml
msgid "General"
msgstr "Загальне"

#: ui/configGeneral.qml
msgid "Polling interval (ms):"
msgstr "Інтервал опитування (мс):"

#: ui/configGeneral.qml
msgid "How often the widget checks if the daemon is running (in milliseconds)."
msgstr "Як часто віджет перевіряє, чи працює daemon (у мілісекундах)."

#: ui/configGeneral.qml
msgid "Show last transcription:"
msgstr "Показати останню транскрипцію:"

#: ui/configGeneral.qml
msgid "Display the last transcribed text in the popup window."
msgstr "Відображати останній транскрибований текст у спливаючому вікні."

#: ui/configGeneral.qml
msgid "Preview mode (test with mic):"
msgstr "Режим попереднього перегляду (тест з мікрофоном):"

#: ui/configGeneral.qml
msgid "Microphone volume:"
msgstr "Гучність мікрофона:"

#: ui/configGeneral.qml
msgid "Adjust the microphone input volume (PipeWire/PulseAudio default source)."
msgstr "Налаштувати вхідну гучність мікрофона (джерело за замовчуванням PipeWire/PulseAudio)."

#: ui/configGeneral.qml
msgid "Noise floor:"
msgstr "Рівень шуму:"

#: ui/configGeneral.qml
msgid "Calibrate"
msgstr "Калібрувати"

#: ui/configGeneral.qml
msgid "Calibration done!"
msgstr "Калібрування завершено!"

#: ui/configGeneral.qml
msgid "Calibration failed"
msgstr "Калібрування не вдалося"

#: ui/configGeneral.qml
msgid "Record 5 seconds of silence to calibrate the background noise level. This improves animation accuracy."
msgstr "Запишіть 5 секунд тиші для калібрування рівня фонового шуму. Це покращує точність анімації."

#: ui/configGeneral.qml
msgid "Noise gate:"
msgstr "Noise gate:"

#: ui/configGeneral.qml
msgid "Audio levels below this threshold are zeroed. Increase to suppress background noise and get clean silence."
msgstr "Рівні звуку нижче цього порогу обнуляються. Збільшіть для придушення фонового шуму та отримання чистої тиші."

#: ui/configGeneral.qml
msgid "Envelope shape:"
msgstr "Форма огинаючої:"

#: ui/configGeneral.qml
msgid "Flat"
msgstr "Плоска"

#: ui/configGeneral.qml
msgid "Normal"
msgstr "Нормальна"

#: ui/configGeneral.qml
msgid "Controls the Hanning envelope shape. 0 = flat (uniform bars), 1 = normal, higher = more peaked at the center."
msgstr "Контролює форму огинаючої Ганна. 0 = плоска (рівномірні смуги), 1 = нормальна, більше = більш загострена в центрі."

#: ui/configGeneral.qml
msgid "Envelope center:"
msgstr "Центр огинаючої:"

#: ui/configGeneral.qml
msgid "Shift the envelope peak across the frequency range (80–4000 Hz). Useful with rainbow colors to emphasize different frequency bands."
msgstr "Зсунути пік огинаючої по діапазону частот (80–4000 Гц). Корисно з веселковими кольорами для виділення різних частотних смуг."

#: ui/configGeneral.qml
msgid "Animation"
msgstr "Анімація"

#: ui/configGeneral.qml
msgid "Animation style:"
msgstr "Стиль анімації:"

#: ui/configGeneral.qml
msgid "Bars (default)"
msgstr "Смуги (за замовчуванням)"

#: ui/configGeneral.qml
msgid "Wave"
msgstr "Хвиля"

#: ui/configGeneral.qml
msgid "Pulse"
msgstr "Пульс"

#: ui/configGeneral.qml
msgid "Dots"
msgstr "Крапки"

#: ui/configGeneral.qml
msgid "Waveform"
msgstr "Хвильова форма"

#: ui/configGeneral.qml
msgid "Rainbow colors:"
msgstr "Веселкові кольори:"

#: ui/configGeneral.qml
msgid "Start hue:"
msgstr "Початковий тон:"

#: ui/configGeneral.qml
msgid "End hue:"
msgstr "Кінцевий тон:"

#: ui/configGeneral.qml
msgid "Preview:"
msgstr "Попередній перегляд:"

#: ui/configGeneral.qml
msgid "Bars settings"
msgstr "Налаштування смуг"

#: ui/configGeneral.qml
msgid "Sensitivity:"
msgstr "Чутливість:"

#: ui/configGeneral.qml
msgid "Number of bars:"
msgstr "Кількість смуг:"

#: ui/configGeneral.qml
msgid "Bar spacing (px):"
msgstr "Відстань між смугами (px):"

#: ui/configGeneral.qml
msgid "Bar corner radius:"
msgstr "Радіус кутів смуг:"

#: ui/configGeneral.qml
msgid "Min height (%):"
msgstr "Мінімальна висота (%):"

#: ui/configGeneral.qml
msgid "Idle breathing animation:"
msgstr "Анімація дихання в режимі очікування:"

#: ui/configGeneral.qml
msgid "Animation speed (ms):"
msgstr "Швидкість анімації (мс):"

#: ui/configGeneral.qml
msgid "Wave settings"
msgstr "Налаштування хвилі"

#: ui/configGeneral.qml
msgid "Width (px):"
msgstr "Ширина (px):"

#: ui/configGeneral.qml
msgid "Line thickness (px):"
msgstr "Товщина лінії (px):"

#: ui/configGeneral.qml
msgid "Wave frequency:"
msgstr "Частота хвилі:"

#: ui/configGeneral.qml
msgid "Amplitude (%):"
msgstr "Амплітуда (%):"

#: ui/configGeneral.qml
msgid "Wave speed (ms):"
msgstr "Швидкість хвилі (мс):"

#: ui/configGeneral.qml
msgid "Fill under wave:"
msgstr "Заповнити під хвилею:"

#: ui/configGeneral.qml
msgid "Pulse settings"
msgstr "Налаштування пульсу"

#: ui/configGeneral.qml
msgid "Number of rings:"
msgstr "Кількість кілець:"

#: ui/configGeneral.qml
msgid "Ring thickness (px):"
msgstr "Товщина кілець (px):"

#: ui/configGeneral.qml
msgid "Pulse speed (ms):"
msgstr "Швидкість пульсу (мс):"

#: ui/configGeneral.qml
msgid "Dots settings"
msgstr "Налаштування крапок"

#: ui/configGeneral.qml
msgid "Number of dots:"
msgstr "Кількість крапок:"

#: ui/configGeneral.qml
msgid "Dot size (px):"
msgstr "Розмір крапок (px):"

#: ui/configGeneral.qml
msgid "Dot spacing (px):"
msgstr "Відстань між крапками (px):"

#: ui/configGeneral.qml
msgid "Bounce amplitude (%):"
msgstr "Амплітуда стрибка (%):"

#: ui/configGeneral.qml
msgid "Bounce speed (ms):"
msgstr "Швидкість стрибка (мс):"

#: ui/configGeneral.qml
msgid "Waveform settings"
msgstr "Налаштування хвильової форми"

#: contents/ui/FullRepresentation.qml
msgid "Reset"
msgstr "Скинути"
