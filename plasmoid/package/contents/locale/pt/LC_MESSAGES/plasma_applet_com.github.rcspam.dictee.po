#: ui/configGeneral.qml
msgid "General"
msgstr "Geral"

#: ui/configGeneral.qml
msgid "Polling interval (ms):"
msgstr "Intervalo de sondagem (ms):"

#: ui/configGeneral.qml
msgid "How often the widget checks if the daemon is running (in milliseconds)."
msgstr "Com que frequência o widget verifica se o daemon está em execução (em milissegundos)."

#: ui/configGeneral.qml
msgid "Show last transcription:"
msgstr "Mostrar última transcrição:"

#: ui/configGeneral.qml
msgid "Display the last transcribed text in the popup window."
msgstr "Mostrar o último texto transcrito na janela popup."

#: ui/configGeneral.qml
msgid "Preview mode (test with mic):"
msgstr "Modo pré-visualização (teste com microfone):"

#: ui/configGeneral.qml
msgid "Microphone volume:"
msgstr "Volume do microfone:"

#: ui/configGeneral.qml
msgid "Adjust the microphone input volume (PipeWire/PulseAudio default source)."
msgstr "Ajustar o volume de entrada do microfone (fonte predefinida PipeWire/PulseAudio)."

#: ui/configGeneral.qml
msgid "Noise floor:"
msgstr "Nível de ruído:"

#: ui/configGeneral.qml
msgid "Calibrate"
msgstr "Calibrar"

#: ui/configGeneral.qml
msgid "Calibration done!"
msgstr "Calibração concluída!"

#: ui/configGeneral.qml
msgid "Calibration failed"
msgstr "Calibração falhada"

#: ui/configGeneral.qml
msgid "Record 5 seconds of silence to calibrate the background noise level. This improves animation accuracy."
msgstr "Grave 5 segundos de silêncio para calibrar o nível de ruído de fundo. Isto melhora a precisão da animação."

#: ui/configGeneral.qml
msgid "Noise gate:"
msgstr "Noise gate:"

#: ui/configGeneral.qml
msgid "Audio levels below this threshold are zeroed. Increase to suppress background noise and get clean silence."
msgstr "Os níveis de áudio abaixo deste limiar são zerados. Aumente para suprimir o ruído de fundo e obter um silêncio limpo."

#: ui/configGeneral.qml
msgid "Envelope shape:"
msgstr "Forma da envolvente:"

#: ui/configGeneral.qml
msgid "Flat"
msgstr "Plano"

#: ui/configGeneral.qml
msgid "Normal"
msgstr "Normal"

#: ui/configGeneral.qml
msgid "Controls the Hanning envelope shape. 0 = flat (uniform bars), 1 = normal, higher = more peaked at the center."
msgstr "Controla a forma da envolvente de Hanning. 0 = plano (barras uniformes), 1 = normal, maior = mais acentuado no centro."

#: ui/configGeneral.qml
msgid "Envelope center:"
msgstr "Centro da envolvente:"

#: ui/configGeneral.qml
msgid "Shift the envelope peak across the frequency range (80–4000 Hz). Useful with rainbow colors to emphasize different frequency bands."
msgstr "Deslocar o pico da envolvente ao longo da gama de frequências (80–4000 Hz). Útil com cores arco-íris para realçar diferentes bandas de frequência."

