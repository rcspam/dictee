msgstr "на початок"

#: dictee-setup.py:4669 dictee-setup.py:5491 dictee-setup.py:6609
msgid "Add"
msgstr "Додати"

#: dictee-setup.py:4673 dictee-setup.py:4977 dictee-setup.py:5000
#: dictee-setup.py:5001 dictee-setup.py:8128
msgid "Record"
msgstr "Записати"

#: dictee-setup.py:4674
