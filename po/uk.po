#: dictee-transcribe.py:575
msgid ""
"Before transcribing audio files, you need to configure the speech "
"recognition engine and other settings.\n"
"\n"
"Would you like to open the configuration wizard?"
msgstr ""
"Перед транскрипцією аудіофайлів потрібно налаштувати систему розпізнавання "
"мовлення та інші параметри.\n"
"\n"
"Бажаєте відкрити майстер налаштування?"

#: dictee-transcribe.py:603
msgid "File:"
msgstr "Файл:"

#: dictee-transcribe.py:607
msgid "Select an audio file..."
msgstr "Оберіть аудіофайл..."

#: dictee-transcribe.py:608
msgid "Path to the audio file to transcribe"
msgstr "Шлях до аудіофайлу для транскрипції"

#: dictee-transcribe.py:612
msgid "Open file selection dialog"
msgstr "Відкрити діалог вибору файлу"

#: dictee-transcribe.py:621
msgid "Speaker identification (diarization)"
msgstr "Ідентифікація мовців (діаризація)"

#: dictee-transcribe.py:626
msgid "Identify speakers (max 4). Recommended for recordings under 5 minutes."
msgstr "Ідентифікувати мовців (макс. 4). Рекомендовано для записів до 5 хвилин."

#: dictee-transcribe.py:632
msgid "Auto-translate the transcription"
msgstr "Автоматично перекласти транскрипцію"

#: dictee-transcribe.py:634
msgid "Automatically translate after transcription"
msgstr "Автоматично перекладати після транскрипції"

#: dictee-transcribe.py:639
msgid "Format:"
msgstr "Формат:"

#: dictee-transcribe.py:643
msgid "Plain text"
msgstr "Звичайний текст"

#: dictee-transcribe.py:646
msgid "Output format for transcription"
msgstr "Формат виводу транскрипції"

#: dictee-transcribe.py:672
msgid "Source language"
msgstr "Мова джерела"

#: dictee-transcribe.py:685
msgid "Target language"
msgstr "Цільова мова"

#: dictee-transcribe.py:696
msgid "Current translation backend"
msgstr "Поточний backend перекладу"

#: dictee-transcribe.py:699
msgid "Configure..."
msgstr "Налаштувати..."

#: dictee-transcribe.py:700
msgid "Open translation settings in dictee-setup"
msgstr "Відкрити налаштування перекладу в dictee-setup"

#: dictee-transcribe.py:715
msgid "Transcribe"
msgstr "Транскрибувати"

#: dictee-transcribe.py:717
msgid "Start transcription of the selected file"
msgstr "Почати транскрипцію обраного файлу"

#: dictee-transcribe.py:721
msgid "Translate"
msgstr "Перекласти"

#: dictee-transcribe.py:723
msgid "Translate the current transcription"
msgstr "Перекласти поточну транскрипцію"

#: dictee-transcribe.py:748
msgid "Transcription results will appear here..."
msgstr "Результати транскрипції з'являться тут..."

#: dictee-transcribe.py:749
msgid "Editable transcription text. Ctrl+F to search, Ctrl+Z to undo."
msgstr "Текст транскрипції для редагування. Ctrl+F — пошук, Ctrl+Z — скасувати."

#: dictee-transcribe.py:750
msgid "Original"
msgstr "Оригінал"

#: dictee-transcribe.py:766
msgid "Copy all"
msgstr "Копіювати все"

#: dictee-transcribe.py:767
msgid "Copy the entire text to the clipboard"
msgstr "Копіювати весь текст у буфер обміну"

#: dictee-transcribe.py:771
msgid "Export..."
msgstr "Експорт..."

#: dictee-transcribe.py:772
msgid "Save the transcription to a file"
msgstr "Зберегти транскрипцію у файл"

#: dictee-transcribe.py:778
msgid "Close"
msgstr "Закрити"

#: dictee-transcribe.py:779
msgid "Close this window"
msgstr "Закрити це вікно"

#: dictee-transcribe.py:931
msgid "Select audio file"
msgstr "Обрати аудіофайл"

#: dictee-transcribe.py:941
msgid "File not found."
msgstr "Файл не знайдено."

#: dictee-transcribe.py:1047
#, python-brace-format
msgid "Command '{cmd}' not found. Install dictee first."
msgstr "Команду «{cmd}» не знайдено. Спочатку встановіть dictee."

#: dictee-transcribe.py:1091
msgid "GPU memory full — unloading translation model and retrying..."
msgstr "Пам'ять GPU заповнена — вивантаження моделі перекладу та повторна спроба..."

#: dictee-transcribe.py:1114
#, python-brace-format
msgid ""
"Transcription failed (code {code}). Check memory, backend, or audio file."
msgstr ""
"Помилка транскрипції (код {code}). Перевірте пам'ять, backend або аудіофайл."

#: dictee-transcribe.py:1189
#, python-brace-format
msgid "{n} speaker(s)"
msgstr "{n} мовець(ів)"

#: dictee-transcribe.py:1190
#, python-brace-format
msgid "audio {dur}"
msgstr "аудіо {dur}"

#: dictee-transcribe.py:1191
#, python-brace-format
msgid "transcribed in {t:.1f}s"
msgstr "транскрибовано за {t:.1f}с"

#: dictee-transcribe.py:1193
#, python-brace-format
msgid "translated in {t:.1f}s"
msgstr "перекладено за {t:.1f}с"

#: dictee-transcribe.py:1210
msgid "Translating..."
msgstr "Переклад..."

#: dictee-transcribe.py:1267
msgid "Editable translation text. Ctrl+F to search, Ctrl+Z to undo."
msgstr "Текст перекладу для редагування. Ctrl+F — пошук, Ctrl+Z — скасувати."

#: dictee-transcribe.py:1357
#, python-brace-format
msgid "Copied {tab} to clipboard."
msgstr "{tab} скопійовано в буфер обміну."

