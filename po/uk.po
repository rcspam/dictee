msgstr "голосові команди, пунктуація, форматування."

msgid "Continuation"
msgstr "Продовження"

msgid "Remove erroneous periods after closed-class words"
msgstr "Видалити помилкові крапки після службових слів,"

msgid "so sentences flow across push-to-talk segments."
msgstr "щоб речення плавно з'єднувались між сегментами push-to-talk."

msgid "Language rules"
msgstr "Мовні правила"

msgid "Per-language fixes:"
msgstr "Виправлення для окремих мов:"

msgid "FR/IT elisions, DE/ES/PT/NL/RO corrections."
msgstr "елізії FR/IT, виправлення DE/ES/PT/NL/RO."

msgid "Numbers"
msgstr "Числа"

msgid "Convert spoken numbers to digits."
msgstr "Перетворити вимовлені числа на цифри."

msgid "Example: \"twenty-three\" → \"23\"."
msgstr "Приклад: \"двадцять три\" → \"23\"."

msgid "Dictionary"
msgstr "Словник"

msgid "Exact word replacements from the system"
msgstr "Точна заміна слів із системного"

msgid "and personal dictionaries."
msgstr "та особистого словників."

msgid "Capitalization"
msgstr "Капіталізація"

msgid "Uppercase first letter after . ! ?"
msgstr "Велика літера після . ! ?"

