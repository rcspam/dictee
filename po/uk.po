msgid "at end"
msgstr "в кінець"

#: dictee-setup.py:4728
msgid "at beginning"
msgstr "на початок"

#: dictee-setup.py:4737 dictee-setup.py:5559 dictee-setup.py:6677
msgid "Add"
msgstr "Додати"

#: dictee-setup.py:4741 dictee-setup.py:5045 dictee-setup.py:5068
#: dictee-setup.py:5069 dictee-setup.py:8239
msgid "Record"
msgstr "Записати"

#: dictee-setup.py:4742
msgid "Record audio, transcribe, and fill the pattern field"
msgstr "Записати аудіо, транскрибувати та заповнити поле шаблону"

#: dictee-setup.py:4759
#, python-brace-format
msgid "User rules in {path} — applied after system rules."
msgstr "Правила користувача в {path} — застосовуються після системних правил."

#: dictee-setup.py:4830 dictee-setup.py:5555
msgid "Search (Ctrl+F)"
