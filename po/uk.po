#: /home/rapha/SOURCES/RAPHA_STT/dictee/dictee-setup.py:15043
msgid ""
"The Canary model is not installed.\n"
"\n"
"Download it from the ASR backend page before enabling Canary."
msgstr ""
"Модель Canary не встановлено.\n"
