#: dictee-setup.py:3410
msgid "Elisions"
msgstr "Elisionen"

#: dictee-setup.py:3413
msgid ""
"Applies French elision rules.\n"
"Example: \"le arbre\" → \"l'arbre\",\n"
"\"de eau\" → \"d'eau\""
msgstr ""
