#: /home/rapha/SOURCES/RAPHA_STT/dictee/dictee-setup.py:1800
msgid "Multilingual transcription (25 languages, ~2.5 GB)"
msgstr "Transcription multilingue (25 langues, ~2,5 Go)"

#: /home/rapha/SOURCES/RAPHA_STT/dictee/dictee-setup.py:1802
msgid ""
"<b>Parakeet-TDT 0.6B v3</b> — Main transcription model<br><br>FastConformer "
"encoder + Token-and-Duration Transducer (TDT) decoder.<br>Supports <b>25 "
"languages</b> including French, English, Spanish, German, etc.<br>Native "
"punctuation and capitalization (no post-processing "
"needed).<br><br><b>Required</b> for all transcription modes (dictation, "
"batch, daemon).<br>Used by: <code>transcribe</code>, <code>transcribe-"
"daemon</code>, <code>transcribe-diarize</code>, <code>dictee</code>"
msgstr ""
"<b>Parakeet-TDT 0.6B v3</b> — Modèle de transcription "
"principal<br><br>Encodeur FastConformer + décodeur TDT (Token-and-Duration "
"Transducer).<br>Supporte <b>25 langues</b> dont le français, l'anglais, "
"l'espagnol, l'allemand, etc.<br>Ponctuation et capitalisation natives (aucun"
" post-traitement nécessaire).<br><br><b>Requis</b> pour tous les modes de "
"transcription (dictée, batch, daemon).<br>Utilisé par : "
"<code>transcribe</code>, <code>transcribe-daemon</code>, <code>transcribe-"
"diarize</code>, <code>dictee</code>"

#: /home/rapha/SOURCES/RAPHA_STT/dictee/dictee-setup.py:1823
msgid "Speaker diarization (4 speakers max, ~50 MB)"
msgstr "Diarisation de locuteurs (4 locuteurs max, ~50 Mo)"

#: /home/rapha/SOURCES/RAPHA_STT/dictee/dictee-setup.py:1825
msgid ""
"<b>Sortformer</b> — Speaker diarization model<br><br>Identifies and "
"separates up to <b>4 different speakers</b> in an audio recording.<br>Labels"
" each transcription segment with the speaker who said "
"it.<br><br><b>Optional</b> — only needed if you want speaker "
"identification.<br>Used by: <code>transcribe-diarize</code>, "
"<code>transcribe-stream-diarize</code>"
msgstr ""
"<b>Sortformer</b> — Modèle de diarisation<br><br>Identifie et sépare jusqu'à"
" <b>4 locuteurs différents</b> dans un enregistrement audio.<br>Attribue "
"chaque segment de transcription au locuteur "
"correspondant.<br><br><b>Optionnel</b> — uniquement nécessaire pour "
"l'identification des locuteurs.<br>Utilisé par : <code>transcribe-"
"diarize</code>, <code>transcribe-stream-diarize</code>"

#: /home/rapha/SOURCES/RAPHA_STT/dictee/dictee-setup.py:1841
msgid "English streaming (~2.5 GB)"
msgstr "Streaming anglais (~2,5 Go)"

#: /home/rapha/SOURCES/RAPHA_STT/dictee/dictee-setup.py:1843
msgid ""
"<b>Nemotron 0.6B</b> — English streaming model<br><br>Optimized for <b>real-"
"time English</b> transcription with low latency.<br>Processes audio in "
"streaming chunks instead of waiting for the full "
"recording.<br><br><b>Optional</b> — only needed for English streaming + "
"diarization mode.<br>Used by: <code>transcribe-stream-diarize</code>"
msgstr ""
"<b>Nemotron 0.6B</b> — Modèle streaming anglais<br><br>Optimisé pour la "
"transcription <b>anglaise en temps réel</b> avec faible latence.<br>Traite "
"l'audio par morceaux au lieu d'attendre l'enregistrement "
"complet.<br><br><b>Optionnel</b> — uniquement nécessaire pour le mode "
"streaming anglais + diarisation.<br>Utilisé par : <code>transcribe-stream-"
"diarize</code>"

