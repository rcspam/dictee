"Contractions : \"a el\" → \"al\", \"de el\" → \"del\"\n"
"Ponctuation : ajoute ¿ avant les questions et ¡ avant les exclamations."

#: dictee-setup.py:7359 dictee-setup.py:7388
msgid "Contractions"
msgstr "Contractions"

#: dictee-setup.py:7362
msgid ""
"Portuguese fused contractions.\n"
"\"de o\" → \"do\", \"em a\" → \"na\", \"por os\" → \"pelos\",\n"
"\"de este\" → \"deste\", \"em ele\" → \"nele\""
msgstr ""
