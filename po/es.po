#: dictee-setup.py:10121
msgid "Elisions"
msgstr "Elisiones"

#: dictee-setup.py:10124
msgid ""
"Applies French elision rules.\n"
"Example: \"le arbre\" → \"l'arbre\",\n"
"\"de eau\" → \"d'eau\""
