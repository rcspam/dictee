#!/bin/bash
# dictee-switch-backend — Switch ASR or translation backend
# Usage: dictee-switch-backend <asr|translate> <backend>
set -euo pipefail

CONF="${XDG_CONFIG_HOME:-$HOME/.config}/dictee.conf"

# Debug (même log que dictee)
_DBG_LOG="/tmp/dictee-debug-$(id -u).log"
_dbg() {
    if [ "${DICTEE_DEBUG:-false}" = "true" ]; then
        printf '%s [switch-backend] %s\n' "$(date '+%H:%M:%S.%3N')" "$*" >> "$_DBG_LOG"
    fi
}
# Charger DICTEE_DEBUG depuis la config si pas déjà défini
if [ -f "$CONF" ] && [ "${DICTEE_DEBUG:-}" != "true" ]; then
    _d=$(grep '^DICTEE_DEBUG=' "$CONF" 2>/dev/null | cut -d= -f2)
    [ "$_d" = "true" ] && export DICTEE_DEBUG=true
fi

usage() {
    echo "Usage: dictee-switch-backend <command> [backend]"
    echo ""
    echo "Commands:"
    echo "  status                    Show current backends"
    echo "  asr <backend>             Switch ASR backend"
    echo "  translate <backend>       Switch translation backend"
    echo "  diarize [true|false|toggle]  Toggle speaker diarization"
    echo ""
    echo "ASR backends:      parakeet, canary, vosk, whisper"
    echo "Translate backends: google, bing, ollama, libretranslate"
    exit 1
}

# Update or append a key=value in dictee.conf
set_conf() {
    local key="$1" value="$2"
    if grep -q "^${key}=" "$CONF"; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$CONF"
    else
        echo "${key}=${value}" >> "$CONF"
    fi
}

if [ ! -f "$CONF" ]; then
    echo "Error: $CONF not found. Run dictee-setup first." >&2
    exit 1
fi

if [ $# -lt 1 ]; then
    usage
fi

_dbg "command=$1 ${2:-}"

case "$1" in
status)
    # Read current backends from config (disable -eu during source to tolerate malformed values)
    set +eu
    source "$CONF"
    set -eu
    asr="${DICTEE_ASR_BACKEND:-parakeet}"
    case "$asr" in
        parakeet) svc="dictee" ;;
        canary)   svc="dictee-canary" ;;
        vosk)     svc="dictee-vosk" ;;
        whisper)  svc="dictee-whisper" ;;
        *)        svc="unknown" ;;
    esac
    svc_state=$(systemctl --user is-active "${svc}.service" 2>/dev/null) || true
    echo "ASR: $asr (${svc}.service, $svc_state)"

    trans="${DICTEE_TRANSLATE_BACKEND:-trans}"
    if [ "$trans" = "trans" ]; then
        engine="${DICTEE_TRANS_ENGINE:-google}"
        echo "Translate: $engine ($trans)"
    else
        echo "Translate: $trans"
    fi
    exit 0
    ;;

asr)
    if [ $# -lt 2 ]; then usage; fi
    # Mapping backend -> service name
    case "$2" in
        parakeet) svc="dictee" ;;
        canary)   svc="dictee-canary" ;;
        vosk)     svc="dictee-vosk" ;;
        whisper)  svc="dictee-whisper" ;;
        *) echo "Error: unknown ASR backend '$2'" >&2; usage ;;
    esac

    # Check service exists
    if ! systemctl --user list-unit-files "${svc}.service" 2>/dev/null | grep -q "${svc}.service"; then
        echo "Error: ${svc}.service not found. Is the $2 backend installed?" >&2
        notify-send -t 5000 -i dialog-error -a Dictee "Backend $2 not installed" 2>/dev/null || true
        exit 1
    fi

    set_conf "DICTEE_ASR_BACKEND" "$2"

    # Signal transitional state to plasmoid/tray (protégé par flock)
    STATE_FILE="/dev/shm/.dictee_state"
    STATE_LOCK="/dev/shm/.dictee_state.lock"
    _write_state() { ( flock -n 200 || return 1; echo "$1" > "$STATE_FILE"; ) 200>"$STATE_LOCK"; }

    _write_state "switching"
    _dbg "asr: switching to $2 (svc=$svc)"

    # Stop all, start the right one
    for s in dictee dictee-canary dictee-vosk dictee-whisper; do
        if [ "$s" != "$svc" ]; then
            systemctl --user stop "${s}.service" 2>/dev/null || true
            systemctl --user disable "${s}.service" 2>/dev/null || true
        fi
    done
    if ! systemctl --user enable --now "${svc}.service" 2>/dev/null; then
        echo "Warning: ${svc}.service failed to start. Check: systemctl --user status ${svc}.service" >&2
        _write_state "offline"
        _dbg "asr: $svc FAILED to start"
    else
        _write_state "idle"
        _dbg "asr: $svc started OK"
    fi

    echo "ASR backend: $2 (${svc}.service)"
    notify-send -t 3000 -i audio-chat-symbolic -a Dictee "Backend ASR: $2" 2>/dev/null || true
    ;;

translate)
    if [ $# -lt 2 ]; then usage; fi
    case "$2" in
        google)
            set_conf "DICTEE_TRANSLATE_BACKEND" "trans"
            set_conf "DICTEE_TRANS_ENGINE" "google"
            ;;
        bing)
            set_conf "DICTEE_TRANSLATE_BACKEND" "trans"
            set_conf "DICTEE_TRANS_ENGINE" "bing"
            ;;
        ollama)
            if ! command -v ollama >/dev/null 2>&1; then
                echo "Error: ollama is not installed. See https://ollama.com" >&2
                notify-send -t 5000 -i dialog-error -a Dictee "Ollama non installé" "Installez ollama depuis https://ollama.com" 2>/dev/null || true
                exit 1
            fi
            set +eu; source "$CONF"; set -eu
            model="${DICTEE_OLLAMA_MODEL:-translategemma}"
            base="${model%%:*}"
            if ! ollama list 2>/dev/null | grep -q "$base"; then
                echo "Error: model '$model' not downloaded. Run: ollama pull $model" >&2
                notify-send -t 5000 -i dialog-warning -a Dictee "Modèle Ollama manquant" "Configurez Ollama dans dictee-setup" 2>/dev/null || true
                exit 1
            fi
            set_conf "DICTEE_TRANSLATE_BACKEND" "ollama"
            ;;
        libretranslate)
            set_conf "DICTEE_TRANSLATE_BACKEND" "libretranslate"
            ;;
        *) echo "Error: unknown translate backend '$2'" >&2; usage ;;
    esac

    echo "Translate backend: $2"
    notify-send -t 3000 -i translate-symbolic -a Dictee "Traduction: $2" 2>/dev/null || true
    ;;

diarize)
    val="${2:-toggle}"
    if [ "$val" = "toggle" ]; then
        set +eu; source "$CONF"; set -eu
        current="${DICTEE_DIARIZE:-false}"
        if [ "$current" = "true" ]; then
            val="false"
        else
            val="true"
        fi
    fi
    set +eu; source "$CONF"; set -eu
    current_asr="${DICTEE_ASR_BACKEND:-parakeet}"

    _dbg "diarize: val=$val current_asr=$current_asr"
    if [ "$val" = "true" ]; then
        # Save current backend and stop daemon to free VRAM for transcribe-diarize CLI
        set_conf "DICTEE_PRE_DIARIZE_BACKEND" "$current_asr"
        set_conf "DICTEE_DIARIZE" "true"
        # Stop all daemons and wait for VRAM release (transcribe-diarize is a CLI)
        # Use disable to prevent auto-restart (re-enabled on diarize false)
        _dbg "diarize: stopping all daemons for VRAM"
        systemctl --user disable --now dictee dictee-vosk dictee-whisper dictee-canary 2>/dev/null
        # Wait until GPU processes are gone (max 5s)
        for i in $(seq 1 10); do
            if ! nvidia-smi --query-compute-apps=name --format=csv,noheader 2>/dev/null | grep -qE "transcribe|python"; then
                break
            fi
            sleep 0.5
        done
        notify-send -t 3000 -i audio-speakers-symbolic -a Dictee "Diarisation activée" 2>/dev/null || true
    else
        set_conf "DICTEE_DIARIZE" "false"
        # Restore previous backend daemon
        pre_backend="${DICTEE_PRE_DIARIZE_BACKEND:-$current_asr}"
        if [ -n "$pre_backend" ]; then
            set_conf "DICTEE_ASR_BACKEND" "$pre_backend"
            case "$pre_backend" in
                vosk)    svc="dictee-vosk" ;;
                whisper) svc="dictee-whisper" ;;
                canary)  svc="dictee-canary" ;;
                *)       svc="dictee" ;;
            esac
            _dbg "diarize: restoring $pre_backend → $svc"
            systemctl --user enable --now "$svc" 2>/dev/null
            set_conf "DICTEE_PRE_DIARIZE_BACKEND" ""
            notify-send -t 3000 -i audio-speakers-symbolic -a Dictee "Diarisation désactivée — retour à $pre_backend" 2>/dev/null || true
        else
            notify-send -t 3000 -i audio-speakers-symbolic -a Dictee "Diarisation désactivée" 2>/dev/null || true
        fi
    fi
    echo "Diarization: $val"
    ;;

*) usage ;;
esac
