#!/bin/bash
# dictee-switch-backend — Switch ASR or translation backend
# Usage: dictee-switch-backend <asr|translate> <backend>
set -euo pipefail

CONF="${XDG_CONFIG_HOME:-$HOME/.config}/dictee.conf"

usage() {
    echo "Usage: dictee-switch-backend <asr|translate> <backend>"
    echo ""
    echo "ASR backends:      parakeet, canary, vosk, whisper"
    echo "Translate backends: google, bing, ollama, libretranslate"
    exit 1
}

# Update or append a key=value in dictee.conf
set_conf() {
    local key="$1" value="$2"
    if grep -q "^${key}=" "$CONF"; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$CONF"
    else
        echo "${key}=${value}" >> "$CONF"
    fi
}

if [ ! -f "$CONF" ]; then
    echo "Error: $CONF not found. Run dictee-setup first." >&2
    exit 1
fi

if [ $# -lt 2 ]; then
    usage
fi

case "$1" in
asr)
    # Mapping backend -> service name
    case "$2" in
        parakeet) svc="dictee" ;;
        canary)   svc="dictee-canary" ;;
        vosk)     svc="dictee-vosk" ;;
        whisper)  svc="dictee-whisper" ;;
        *) echo "Error: unknown ASR backend '$2'" >&2; usage ;;
    esac

    # Check service exists
    if ! systemctl --user list-unit-files "${svc}.service" 2>/dev/null | grep -q "${svc}.service"; then
        echo "Warning: ${svc}.service not found" >&2
    fi

    set_conf "DICTEE_ASR_BACKEND" "$2"

    # Stop all, start the right one
    for s in dictee dictee-canary dictee-vosk dictee-whisper; do
        if [ "$s" != "$svc" ]; then
            systemctl --user stop "${s}.service" 2>/dev/null || true
            systemctl --user disable "${s}.service" 2>/dev/null || true
        fi
    done
    if ! systemctl --user enable --now "${svc}.service" 2>/dev/null; then
        echo "Warning: ${svc}.service failed to start. Check: systemctl --user status ${svc}.service" >&2
    fi

    echo "ASR backend: $2 (${svc}.service)"
    notify-send -t 3000 -i audio-chat-symbolic -a Dictee "Backend ASR: $2" 2>/dev/null || true
    ;;

translate)
    case "$2" in
        google)
            set_conf "DICTEE_TRANSLATE_BACKEND" "trans"
            set_conf "DICTEE_TRANS_ENGINE" "google"
            ;;
        bing)
            set_conf "DICTEE_TRANSLATE_BACKEND" "trans"
            set_conf "DICTEE_TRANS_ENGINE" "bing"
            ;;
        ollama)
            set_conf "DICTEE_TRANSLATE_BACKEND" "ollama"
            ;;
        libretranslate)
            set_conf "DICTEE_TRANSLATE_BACKEND" "libretranslate"
            ;;
        *) echo "Error: unknown translate backend '$2'" >&2; usage ;;
    esac

    echo "Translate backend: $2"
    notify-send -t 3000 -i translate-symbolic -a Dictee "Traduction: $2" 2>/dev/null || true
    ;;

*) usage ;;
esac
