        self._btn_close = QPushButton("×")
        self._btn_close.setObjectName("CheatsheetHeaderBtn")
        self._btn_close.setToolTip("Close")
        self._btn_close.clicked.connect(self.hide)
        layout.addWidget(self._btn_close)

