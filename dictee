#!/bin/bash
#
# Dictée vocale - enregistre avec le micro, transcrit et tape le texte
# Optionnellement traduit avant d'envoyer
#
# Backends traduction: trans (défaut), ollama (translategemma)
# Langues configurables via variables d'environnement :
#   DICTEE_LANG_SOURCE (défaut: langue système), DICTEE_LANG_TARGET (défaut: en)
#
# Usage: dictee [--translate] [--ollama] [--cancel] [--setup [--wizard]]
#   dictee                      # transcrit et tape
#   dictee --translate          # transcrit, traduit (trans), tape
#   dictee --translate --ollama # traduit avec ollama/translategemma
#   dictee --cancel             # annule l'enregistrement en cours
#   dictee --setup              # ouvre l'interface de configuration
#   dictee --setup --wizard     # ouvre l'assistant de configuration
#
# Nécessite : transcribe-daemon (en cours), pw-record, dotool
# Optionnel : animation-speech-ctl (https://github.com/rcspam/animation-speech)

# === CONFIGURATION ===

# Charger la configuration (dictee-setup)
DICTEE_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/dictee.conf"
if [ -f "$DICTEE_CONF" ]; then
    source "$DICTEE_CONF"
fi

# Parse --help before config guard (works without config)
case "${1:-}" in
    --help|-h)
        head -n 18 "$0" | grep '^#' | sed 's/^# \?//'
        exit 0
        ;;
esac

# First-run guard: launch wizard if no config or setup not completed
if [ ! -f "$DICTEE_CONF" ] || ! grep -q "DICTEE_SETUP_DONE=true" "$DICTEE_CONF" 2>/dev/null; then
    exec dictee-setup --wizard
fi

# Exporter OLLAMA_NUM_GPU si défini dans la config (mode CPU forcé)
[ -n "$OLLAMA_NUM_GPU" ] && export OLLAMA_NUM_GPU

LANG_SOURCE="${DICTEE_LANG_SOURCE:-${LANG%%_*}}"
LANG_TARGET="${DICTEE_LANG_TARGET:-en}"
LANG_LABEL="${LANG_SOURCE^^}→${LANG_TARGET^^}"
CLIPBOARD="${DICTEE_CLIPBOARD:-true}"
ANIMATION="${DICTEE_ANIMATION:-speech}"
DIARIZE="${DICTEE_DIARIZE:-false}"

# Détection du layout clavier pour dotool (localectl > setxkbmap > us)
if [ -z "$DOTOOL_XKB_LAYOUT" ]; then
    DOTOOL_XKB_LAYOUT=$(localectl status 2>/dev/null | awk '/X11 Layout/{print $3}')
    [ -z "$DOTOOL_XKB_LAYOUT" ] && DOTOOL_XKB_LAYOUT=$(setxkbmap -query 2>/dev/null | awk '/layout/{print $2}')
    DOTOOL_XKB_LAYOUT="${DOTOOL_XKB_LAYOUT:-us}"
fi
export DOTOOL_XKB_LAYOUT

RECORDING_FILE="$HOME/.cache/tmp_recording_dictee.wav"
_UID_SUFFIX="-$(id -u)"
PIDFILE="/tmp/recording_dictee_pid${_UID_SUFFIX}"
ID_TMP_FILE="/tmp/notify_dictee${_UID_SUFFIX}"
MUT_FILE="/tmp/mut_dictee${_UID_SUFFIX}"
TRANSLATE_BACKEND_FILE="/tmp/translate_dictee_backend${_UID_SUFFIX}"
TRANSLATE_FLAG_FILE="/tmp/dictee_translate${_UID_SUFFIX}"
LAST_WORD_FILE="/dev/shm/.dictee_last_word"

# État partagé avec plasmoid/tray (protégé par flock)
STATE_FILE="/dev/shm/.dictee_state"
STATE_LOCK="/dev/shm/.dictee_state.lock"

write_state() {
    (
        flock -n 200 || return 1
        echo "$1" > "$STATE_FILE"
    ) 200>"$STATE_LOCK"
}

# Post-traitement du texte (règles regex + dictionnaire + LLM optionnel)
if [ "${DICTEE_POSTPROCESS:-true}" = "true" ] && command -v dictee-postprocess >/dev/null 2>&1; then
    SUPPRIME="| dictee-postprocess"
else
    SUPPRIME=""
fi

# Wrapper dotool safe pour trap ERR
safe_dotool() {
    if dotool 2>/dev/null; then true; fi
}

# Tape du texte via dotool, avec gestion des sauts de ligne et sanitisation
# dotool ne supporte pas : U+00A0, U+202F, …, —, –, tab
# On les remplace par leurs équivalents ASCII avant envoi
type_text() {
    local text="$1"
    # Sanitiser les caractères non supportés par dotool (sans subshell pour préserver \n)
    text="${text//$'\xc2\xa0'/ }"
    text="${text//$'\xe2\x80\xaf'/ }"
    text="${text//$'\xe2\x80\xa6'/...}"
    text="${text//$'\xe2\x80\x94'/--}"
    text="${text//$'\xe2\x80\x93'/-}"
    # Convertir en commandes dotool : "type ..." + "key enter/tab" entre segments
    printf '%s\n' "$text" | awk -v RS='\n' '{
        if (NR > 1) print "key enter"
        # Découper sur les tabs
        n = split($0, parts, "\t")
        for (i = 1; i <= n; i++) {
            if (i > 1) print "key tab"
            if (parts[i] != "") printf "type %s\n", parts[i]
        }
    }' | safe_dotool
}

# Continuation inter-appuis : détection de phrase incomplète
# Mots de classes fermées qui indiquent une phrase non terminée — chargés depuis
# continuation.conf.default (système) + ~/.config/dictee/continuation.conf (utilisateur)
load_continuation_words() {
    local file
    for file in "$@"; do
        [ -f "$file" ] || continue
        while IFS= read -r line; do
            line="${line%%#*}"             # supprimer commentaires
            line="${line#"${line%%[! ]*}"}" # trim début
            [[ "$line" == \[* ]] || continue
            local tag="${line%%]*}"
            tag="${tag#[}"
            # Skip [keyword:*] lines — handled separately
            [[ "$tag" == keyword* ]] && continue
            local words="${line#*]}"
            local var="CONTINUATION_WORDS_${tag^^}"
            # Ajouter les mots (cumulatif)
            eval "${var}=\"\${${var}:-\" \"}\${words} \""
        done < "$file"
    done
}

_SCRIPT_DIR_CONT="$(dirname "$(readlink -f "$0")")"
_SYSTEM_CONT=""
for _c in "$_SCRIPT_DIR_CONT/continuation.conf.default" \
          "/usr/share/dictee/continuation.conf.default" \
          "${XDG_DATA_HOME:-$HOME/.local/share}/dictee/continuation.conf.default"; do
    [ -f "$_c" ] && { _SYSTEM_CONT="$_c"; break; }
done
_USER_CONT="${XDG_CONFIG_HOME:-$HOME/.config}/dictee/continuation.conf"

load_continuation_words ${_SYSTEM_CONT:+"$_SYSTEM_CONT"} ${_USER_CONT:+"$_USER_CONT"}

# Build regex for continuation keyword
# Search order: [keyword:LANG] in user, [keyword:LANG] in system, [keyword] in user, [keyword] in system
_CONT_KEYWORD=""
_LANG_TAG="${LANG_SOURCE:-fr}"
for _pattern in "\\[keyword:${_LANG_TAG}\\]" "\\[keyword\\]"; do
    [ -n "$_CONT_KEYWORD" ] && break
    for _cf in ${_USER_CONT:+"$_USER_CONT"} ${_SYSTEM_CONT:+"$_SYSTEM_CONT"}; do
        [ -f "$_cf" ] || continue
        _match=$(grep -m1 "^\\s*${_pattern}" "$_cf" 2>/dev/null) || continue
        _CONT_KEYWORD="${_match#*] }"
        _CONT_KEYWORD="${_CONT_KEYWORD#"${_CONT_KEYWORD%%[! ]*}"}"
        break 2
    done
done
_CONT_KEYWORD="${_CONT_KEYWORD:-contre-point}"
_CONT_KEYWORD_RE=""
if [ -n "$_CONT_KEYWORD" ]; then
    _kw="${_CONT_KEYWORD,,}"
    # Replace spaces and hyphens with [- ]? to match all variants
    # Use placeholder to avoid double substitution
    _kw="${_kw//-/§}"
    _kw="${_kw// /§}"
    _kw="${_kw//§/[- ]?}"
    _first="${_kw:0:1}"
    _upper="${_first^^}"
    _kw="[${_first}${_upper}]${_kw:1}"
    _CONT_KEYWORD_RE="^${_kw}[.,]?[[:space:]]*(.*)"
    unset _kw _first _upper
fi

apply_continuation() {
    # Usage : apply_continuation VARNAME
    # Modifie la variable en place (pas de subshell)
    # Marqueurs du buffer :
    #   , → virgule (toujours continuation, espace + minuscule)
    #   .N → point(s) (continuation si dernier mot est de classe fermée, sinon espace + garder casse)
    #   F → fin de phrase (! ; : » )) — espace + garder casse
    #   _ → pas de ponctuation (mi-phrase, espace + minuscule)
    local -n _ref="$1"
    # Si le texte commence par \n (commande "à la ligne"), ne pas modifier
    if [[ "$_ref" == $'\n'* ]]; then return; fi
    if [ ! -f "$LAST_WORD_FILE" ]; then return; fi
    local saved
    saved=$(cat "$LAST_WORD_FILE" 2>/dev/null) || return
    local last_char="${saved%%:*}"
    local last_word="${saved#*:}"

    # Supprimer les espaces en début (éviter doubles espaces si texte
    # précédent avait un espace final, ex: "Bonjour, ")
    _ref="${_ref#"${_ref%%[! ]*}"}"

    # Continuation keyword: remove last punctuation + lowercase
    # Configurable via DICTEE_CONTINUATION_KEYWORD (default: contre-point)
    if [ -n "$_CONT_KEYWORD_RE" ] && [[ "$_ref" =~ $_CONT_KEYWORD_RE ]]; then
        local rest="${BASH_REMATCH[1]}"
        # Backspace the punctuation from the previous push
        if [[ "$last_char" == .* ]]; then
            local bs_count="${last_char#.}"
            bs_count="${bs_count:-1}"
            for ((i=0; i<bs_count; i++)); do
                printf 'key backspace\n'
            done | safe_dotool
        elif [[ "$last_char" == [,F] ]]; then
            printf 'key backspace\n' | safe_dotool
        fi
        # Set text to rest in lowercase (or empty if nothing follows)
        if [ -n "$rest" ]; then
            _ref=" ${rest,}"
        else
            _ref=""
        fi
        return
    fi

    # Si le push commence par une ponctuation (commande vocale "virgule",
    # "point", etc.), l'attacher au texte précédent sans espace.
    local fc="${_ref:0:1}"
    if [[ "$fc" == [,.\;!?:] ]]; then
        # Si le précédent était un point/ponctuation, l'effacer :
        # l'utilisateur corrige explicitement la ponctuation
        if [[ "$last_char" == .* ]]; then
            local bs_count="${last_char#.}"
            bs_count="${bs_count:-1}"
            for ((i=0; i<bs_count; i++)); do
                printf 'key backspace\n'
            done | safe_dotool
        elif [[ "$last_char" == [,F] ]]; then
            printf 'key backspace\n' | safe_dotool
        fi
        # Minuscule seulement après , ; : (continuation)
        # Garder la casse après . ! ? (nouvelle phrase)
        # Exception : si le prefix contient \n (ex: ":\n"), c'est un nouveau
        # paragraphe → garder la casse (majuscule)
        if [[ "$fc" == [,\;:] ]]; then
            local prefix="${_ref%%[A-Za-zÀ-ÿ]*}"
            if [[ "$prefix" != *$'\n'* ]]; then
                local after="${_ref#"$prefix"}"
                if [ -n "$after" ]; then
                    _ref="${prefix}${after,}"
                fi
            fi
        fi
        return
    fi

    if [ "$last_char" = "," ]; then
        # Après virgule : toujours continuer (espace + minuscule)
        _ref=" ${_ref,}"
    elif [[ "$last_char" == .* ]]; then
        # Après point(s) : continuer seulement si le dernier mot est de classe fermée
        # Marker format: .N where N = number of backspaces (1, 2, or 3)
        local lower="${last_word,,}"
        local _cw_var="CONTINUATION_WORDS_${LANG_SOURCE^^}"
        local _cw="${!_cw_var}"
        if [[ -n "$_cw" && "$_cw" == *" $lower "* ]]; then
            local bs_count="${last_char#.}"
            bs_count="${bs_count:-1}"
            local bs_cmd=""
            for ((i=0; i<bs_count; i++)); do
                bs_cmd+="key backspace
"
            done
            printf '%s' "$bs_cmd" | safe_dotool
            _ref=" ${_ref,}"
        else
            # Phrase terminée : espace, garder la casse
            _ref=" ${_ref}"
        fi
    elif [ "$last_char" = "F" ]; then
        # Après ! ? … ; : » ) : phrase terminée, espace + garder la casse
        _ref=" ${_ref}"
    elif [ "$last_char" = "_" ]; then
        # Pas de ponctuation : mi-phrase, espace + minuscule
        _ref=" ${_ref,}"
    fi
}

save_last_word() {
    # Sauver le marqueur de ponctuation et le dernier mot pour la continuation
    # Marqueurs : , . F (fin: ! ? … ; : » )) _ (pas de ponctuation)
    local text="$1"
    # Si le texte contient un \n (commande vocale "à la ligne"),
    # ne pas sauver : le prochain appui est indépendant
    if [[ "$text" == *$'\n'* ]]; then
        rm -f "$LAST_WORD_FILE"
        return
    fi
    # Supprimer les espaces de fin (bash pur, pas de subshell)
    local trimmed="${text%"${text##*[! ]}"}"
    if [ -z "$trimmed" ]; then
        rm -f "$LAST_WORD_FILE"
        return
    fi

    local marker="" stripped=""

    # Vérifier les patterns multi-caractères d'abord (points de suspension)
    # Marker encodes backspace count: .3 = "...", .2 = "..", .1 = "…" or "."
    if [[ "$trimmed" == *... ]]; then
        marker=".3"
        stripped="${trimmed%...}"
    elif [[ "$trimmed" == *.. ]]; then
        marker=".2"
        stripped="${trimmed%..}"
    elif [[ "$trimmed" == *$'\xe2\x80\xa6' ]]; then
        # … (U+2026) — type_text() converts to "..." (3 ASCII chars) → 3 backspaces
        marker=".3"
        stripped="${trimmed%?}"
    else
        local last_char="${trimmed: -1}"
        stripped="${trimmed%?}"
        case "$last_char" in
            .)  marker=".1" ;;
            ,)  marker="," ;;
            '?')  # French typography adds NNBSP before ? → 2 backspaces; other languages → 1
                if [ "${LANG_SOURCE:-}" = "fr" ]; then marker=".2"; else marker=".1"; fi ;;
            '!')  # Same NNBSP logic for !
                if [ "${LANG_SOURCE:-}" = "fr" ]; then marker=".2"; else marker="F"; fi ;;
            ';'|':'|$'\xbb')  marker="F" ;;
            ')')  marker="F" ;;
            *)  marker="_" ; stripped="$trimmed" ;;
        esac
    fi

    # Extraire le dernier mot (avant la ponctuation)
    if [ "$marker" != "_" ]; then
        stripped="${stripped%"${stripped##*[! ]}"}"
    fi
    local last_word="${stripped##* }"
    # Handle hyphenated words: "parles-tu" → check "tu" for continuation
    if [[ "$last_word" == *-* ]]; then
        last_word="${last_word##*-}"
    fi

    if [ -n "$last_word" ]; then
        echo "${marker}:${last_word}" > "$LAST_WORD_FILE"
    else
        rm -f "$LAST_WORD_FILE"
    fi
}

# Parse arguments — les valeurs de dictee.conf servent de défaut,
# les arguments CLI les surchargent.
TRANSLATE_BACKEND="${DICTEE_TRANSLATE_BACKEND:-trans}"
TRANSLATE="${DICTEE_TRANSLATE:-false}"
CANCEL=false
NO_ESC_LISTENER=false

for arg in "$@"; do
    case "$arg" in
    --cancel)
        CANCEL=true
        ;;
    --no-esc-listener)
        NO_ESC_LISTENER=true
        ;;
    --translate)
        TRANSLATE=true
        ;;
    --ollama)
        TRANSLATE_BACKEND="ollama"
        ;;
    --setup)
        shift
        exec dictee-setup "$@"
        ;;
    --wizard)
        exec dictee-setup --wizard
        ;;
    --help|-h)
        head -n 18 "$0" | grep '^#' | sed 's/^# \?//'
        exit 0
        ;;
    esac
done

# === FONCTIONS ===

# === ÉCOUTE ESCAPE (/dev/input) ===

ESC_LISTENER_PIDFILE="/tmp/dictee_esc_listener_pid${_UID_SUFFIX}"

start_escape_listener() {
    # Lance un listener en arrière-plan qui lit /dev/input pour détecter ESC
    # Écoute tous les claviers simultanément. Nécessite le groupe 'input'.
    stop_escape_listener
    # Trouver tous les claviers physiques (sysrq+kbd = vrai clavier, exclure virtuels)
    local kbd_devs
    kbd_devs=$(awk -f <(cat << 'AWKEOF'
/^N:/ { name = $0 }
/^H:.*sysrq.*kbd/ {
    if (name !~ /virtual|Virtual|uinput/) {
        match($0, /event[0-9]+/)
        if (RSTART) print "/dev/input/" substr($0, RSTART, RLENGTH)
    }
}
AWKEOF
    ) /proc/bus/input/devices)
    if [ -z "$kbd_devs" ]; then return; fi
    local self_path
    self_path="$(readlink -f "$0")"
    nohup python3 -c "
import struct, subprocess, signal, select, os
signal.signal(signal.SIGTERM, lambda *_: exit(0))
devs = '''$kbd_devs'''.strip().split('\n')
fds = []
for d in devs:
    try:
        fds.append(open(d, 'rb'))
    except (PermissionError, FileNotFoundError):
        pass
if not fds:
    exit(1)
while True:
    ready, _, _ = select.select(fds, [], [])
    for f in ready:
        data = f.read(24)
        if len(data) < 24:
            continue
        _s, _u, t, code, val = struct.unpack('llHHi', data)
        if t == 1 and code == 1 and val == 1:
            for ff in fds:
                ff.close()
            subprocess.Popen(['$self_path', '--cancel'])
            exit(0)
" >/dev/null 2>&1 &
    echo $! > "$ESC_LISTENER_PIDFILE"
    disown $!
}

stop_escape_listener() {
    if [ -f "$ESC_LISTENER_PIDFILE" ]; then
        local pid=""
        if pid=$(cat "$ESC_LISTENER_PIDFILE" 2>/dev/null); then
            if [ -n "$pid" ]; then
                if kill "$pid" 2>/dev/null; then true; fi
                if pkill -P "$pid" 2>/dev/null; then true; fi
            fi
        fi
        rm -f "$ESC_LISTENER_PIDFILE"
    fi
}

# === CLIPBOARD ===

copy_to_clipboard() {
    [ "$CLIPBOARD" = true ] || return 0
    if command -v wl-copy >/dev/null 2>&1 && [ "$XDG_SESSION_TYPE" = "wayland" ]; then
        echo "$1" | wl-copy
    elif command -v xclip >/dev/null 2>&1; then
        echo "$1" | xclip -selection clipboard
    elif command -v xsel >/dev/null 2>&1; then
        echo "$1" | xsel --clipboard --input
    fi
}

# === DÉPENDANCES ===

check_dependencies() {
    local missing=()
    command -v pw-record >/dev/null || missing+=("pipewire")
    # wl-copy / xclip / xsel est optionnel (copie dans le presse-papier en bonus)
    command -v dotool >/dev/null || missing+=("dotool")
    if ! command -v pactl >/dev/null; then
        missing+=("pulseaudio-utils or pipewire-pulse")
    fi
    command -v notify-send >/dev/null || missing+=("libnotify-bin")

    # Vérifier le backend de traduction si --translate
    if [ "$TRANSLATE" = true ]; then
        if [ "$TRANSLATE_BACKEND" = "trans" ]; then
            command -v trans >/dev/null || missing+=("translate-shell")
        elif [ "$TRANSLATE_BACKEND" = "libretranslate" ]; then
            command -v curl >/dev/null || missing+=("curl")
        elif [ "$TRANSLATE_BACKEND" = "ollama" ]; then
            command -v ollama >/dev/null || missing+=("ollama")
        fi
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        echo "Dépendances manquantes: ${missing[*]}" >&2
        exit 1
    fi
}

cleanup_on_error() {
    local exit_code=$?
    local err_line="${1:-unknown}"
    echo "$(date '+%F %T') ERR exit=$exit_code line=$err_line" >> "/tmp/dictee-error${_UID_SUFFIX}.log"

    stop_escape_listener

    # Tuer pw-record et ses enfants
    if [ -f "$PIDFILE" ]; then
        local rec_pid=$(cat "$PIDFILE")
        kill -- -"$rec_pid" 2>/dev/null || kill "$rec_pid" 2>/dev/null
        sleep 0.1
        kill -9 -- -"$rec_pid" 2>/dev/null || kill -9 "$rec_pid" 2>/dev/null
        rm -f "$PIDFILE" "${PIDFILE}.lock"
    fi

    # Arrêter l'animation
    if [ "$ANIMATION" = "speech" ] || [ "$ANIMATION" = "both" ]; then
        if command -v animation-speech-ctl >/dev/null 2>&1; then
            animation-speech-ctl quit 2>/dev/null
        fi
    fi

    # Tuer tous les processus enfants restants
    pkill -P $$ 2>/dev/null

    # Restaurer l'état audio
    pactl set-sink-mute @DEFAULT_SINK@ 0
    if [ -f "$MUT_FILE" ]; then
        [[ $(awk -F"=" '{print $2}' "$MUT_FILE") == 1 ]] && pactl set-source-mute @DEFAULT_SOURCE@ 1
        rm -f "$MUT_FILE"
    fi

    # Fermer la notification persistante
    local id=$(cat "$ID_TMP_FILE" 2>/dev/null)
    if [ -n "$id" ]; then
        notify-send --replace-id="$id" -t 3000 -i audio-chat-none-symbolic -a Dictee "Enregistrement interrompu"
    fi

    rm -f "$ID_TMP_FILE" "$RECORDING_FILE" "$TRANSLATE_BACKEND_FILE" "$TRANSLATE_FLAG_FILE" "$LAST_WORD_FILE"

    write_state "idle"
    exit $exit_code
}

transcribe() {
    local audio_file="$1"
    eval transcribe-client "$audio_file" $SUPPRIME
}

transcribe_canary_translate() {
    # Send WAV path + target language to Canary daemon via extended protocol
    local audio_file="$1"
    local target_lang="$2"
    local sock_path="${XDG_RUNTIME_DIR:-/tmp}/transcribe.sock"
    if [ ! -S "$sock_path" ]; then
        sock_path="/tmp/transcribe-$(id -u).sock"
    fi
    printf '%s\tlang:%s\n' "$audio_file" "$target_lang" | \
        python3 -c "
import socket, sys
sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
sock.connect('$sock_path')
sock.sendall(sys.stdin.buffer.read())
data = b''
while True:
    chunk = sock.recv(4096)
    if not chunk:
        break
    data += chunk
sock.close()
sys.stdout.buffer.write(data)
"
}

translate() {
    local text="$1"
    local backend="$2"

    case "$backend" in
    trans)
        local engine="${DICTEE_TRANS_ENGINE:-google}"
        echo "$text" | timeout 15 trans -b -e "$engine" "${LANG_SOURCE}:${LANG_TARGET}"
        ;;
    libretranslate)
        local port="${DICTEE_LIBRETRANSLATE_PORT:-5000}"
        local base_url="http://localhost:${port}"
        # Vérifier que LibreTranslate est accessible et que les langues sont disponibles
        local avail_langs
        if ! avail_langs=$(curl -s --max-time 3 --connect-timeout 2 "${base_url}/languages" 2>/dev/null) || [ -z "$avail_langs" ]; then
            echo "Erreur LibreTranslate: serveur inaccessible sur le port ${port}. Vérifier que le conteneur Docker est démarré et le réseau disponible." >&2
            return 1
        fi
        local missing=""
        if ! echo "$avail_langs" | python3 -c "import json,sys; codes=[l['code'] for l in json.load(sys.stdin)]; sys.exit(0 if '${LANG_SOURCE}' in codes else 1)" 2>/dev/null; then
            missing="${LANG_SOURCE}"
        fi
        if ! echo "$avail_langs" | python3 -c "import json,sys; codes=[l['code'] for l in json.load(sys.stdin)]; sys.exit(0 if '${LANG_TARGET}' in codes else 1)" 2>/dev/null; then
            if [ -n "$missing" ]; then
                missing="${missing}, ${LANG_TARGET}"
            else
                missing="${LANG_TARGET}"
            fi
        fi
        if [ -n "$missing" ]; then
            local supported
            supported=$(echo "$avail_langs" | python3 -c "import json,sys; print(', '.join(l['code'] for l in json.load(sys.stdin)))" 2>/dev/null)
            echo "Erreur LibreTranslate: langue(s) non disponible(s): ${missing} (disponibles: ${supported}). Relancer le conteneur Docker avec --load-only incluant ces langues." >&2
            return 1
        fi
        # Échapper le texte pour JSON
        local json_text
        json_text=$(printf '%s' "$text" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')
        local result
        result=$(curl -s --max-time 10 "${base_url}/translate" \
            -H "Content-Type: application/json" \
            -d "{\"q\":${json_text},\"source\":\"${LANG_SOURCE}\",\"target\":\"${LANG_TARGET}\"}")
        if echo "$result" | python3 -c 'import json,sys; d=json.load(sys.stdin); print(d["translatedText"])' 2>/dev/null; then
            :
        else
            echo "Erreur LibreTranslate: $result" >&2
            return 1
        fi
        ;;
    ollama)
        local model="${DICTEE_OLLAMA_MODEL:-translategemma}"
        # Vérifier si le modèle est déjà téléchargé
        if ! ollama list 2>/dev/null | grep -q "${model%%:*}"; then
            notify-send -t 0 -i emblem-downloads -a Dictee "Téléchargement du modèle ${model}..." "Premier lancement, veuillez patienter"
        fi
        local prompt="You are a professional ${LANG_SOURCE} to ${LANG_TARGET} translator. Your goal is to accurately convey the meaning and nuances of the original text while adhering to the target language grammar, vocabulary, and cultural sensitivities.
Produce only the ${LANG_TARGET} translation, without any additional explanations or commentary. Please translate the following text:

${text}"
        # Ajouter :latest seulement si pas de tag explicite
        [[ "$model" == *:* ]] || model="${model}:latest"
        timeout 30 ollama run "$model" "$prompt" 2>/dev/null
        ;;
    *)
        echo "Backend traduction inconnu: $backend" >&2
        return 1
        ;;
    esac
}

# === MAIN ===

check_dependencies
trap 'cleanup_on_error $LINENO' INT TERM HUP QUIT ERR

# === ANNULATION (idempotent via flock) ===
if [ "$CANCEL" = true ]; then
    trap - ERR
    (
        flock -n 200 || exit 0          # un autre cancel tient le verrou → no-op
        current=$(cat "$STATE_FILE" 2>/dev/null)
        if [ "$current" = "cancelled" ]; then exit 0; fi  # déjà annulé
        if [ "$current" = "idle" ]; then exit 0; fi        # rien à annuler
        echo "cancelled" > "$STATE_FILE"
    ) 200>"$STATE_LOCK"

    if [ -f "$PIDFILE" ]; then
        id=$(cat "$ID_TMP_FILE" 2>/dev/null)

        stop_escape_listener

        # Arrêter l'animation
        if [ "$ANIMATION" = "speech" ] || [ "$ANIMATION" = "both" ]; then
            if command -v animation-speech-ctl >/dev/null 2>&1; then
                if animation-speech-ctl quit 2>/dev/null; then true; fi
            fi
        fi

        # Restaurer l'état du micro
        if [ -f "$MUT_FILE" ]; then
            was_muted=""
            if was_muted=$(awk -F"=" '{print $2}' "$MUT_FILE" 2>/dev/null); then
                if [ "$was_muted" = "1" ]; then
                    pactl set-source-mute @DEFAULT_SOURCE@ 1
                fi
            fi
            rm -f "$MUT_FILE"
        fi
        pactl set-sink-mute @DEFAULT_SINK@ 0

        # Arrêter l'enregistrement
        if [ -f "$PIDFILE" ]; then
            cancel_pid=""
            if cancel_pid=$(cat "$PIDFILE" 2>/dev/null); then
                if [ -n "$cancel_pid" ]; then
                    if kill "$cancel_pid" 2>/dev/null; then
                        true
                    fi
                fi
            fi
            rm -f "$PIDFILE" "${PIDFILE}.lock"
        fi

        if [ -n "$id" ]; then
            notify-send --replace-id="$id" -t 3000 -i audio-chat-none-symbolic -a Dictee "Enregistrement annulé"
        else
            notify-send -t 3000 -i audio-chat-none-symbolic -a Dictee "Enregistrement annulé"
        fi
        rm -f "$ID_TMP_FILE" "$RECORDING_FILE" "$TRANSLATE_BACKEND_FILE" "$TRANSLATE_FLAG_FILE"
    fi
    exit 0
fi

if [ -f "$PIDFILE" ]; then
    # === ARRÊT DE L'ENREGISTREMENT ===
    # Désactiver trap ERR pendant cette section (trop de commandes externes
    # qui peuvent retourner non-zéro légitimement : kill, pactl, ffmpeg, etc.)
    trap - ERR

    stop_escape_listener

    # Récupérer les options utilisées au démarrage
    if [ -f "$TRANSLATE_FLAG_FILE" ]; then
        TRANSLATE=true
    fi
    if [ -f "$TRANSLATE_BACKEND_FILE" ]; then
        TRANSLATE_BACKEND=$(cat "$TRANSLATE_BACKEND_FILE")
    fi

    id=$(cat "$ID_TMP_FILE" 2>/dev/null)

    # Arrêter l'animation
    if [ "$ANIMATION" = "speech" ] || [ "$ANIMATION" = "both" ]; then
        if command -v animation-speech-ctl >/dev/null 2>&1; then
            if animation-speech-ctl stop 2>/dev/null; then true; fi
        fi
    fi

    # Restaurer l'état du micro
    if [ -f "$MUT_FILE" ]; then
        was_muted=""
        if was_muted=$(awk -F"=" '{print $2}' "$MUT_FILE" 2>/dev/null); then
            if [ "$was_muted" = "1" ]; then
                pactl set-source-mute @DEFAULT_SOURCE@ 1
            fi
        fi
        rm -f "$MUT_FILE"
    fi
    # Démuter le son
    pactl set-sink-mute @DEFAULT_SINK@ 0

    # Signaler au plasmoid
    write_state "transcribing"

    # Arrêter l'enregistrement
    if [ -f "$PIDFILE" ]; then
        rec_pid=""
        if rec_pid=$(cat "$PIDFILE" 2>/dev/null); then
            if [ -n "$rec_pid" ]; then
                if kill "$rec_pid" 2>/dev/null; then
                    true
                fi
            fi
        fi
        rm -f "$PIDFILE" "${PIDFILE}.lock"
    fi

    if [ -n "$id" ]; then
        notify-send --replace-id="$id" -t 3000 -i audio-chat-none-symbolic -a Dictee "Enregistrement arrêté"
    fi

    # Diarisation live : copier le WAV et ouvrir dictee-transcribe
    if [ "$DIARIZE" = "true" ]; then
        write_state "idle"
        # Ensure daemon is stopped and VRAM is freed (tray doesn't wait for switch-backend)
        for svc in dictee dictee-vosk dictee-whisper dictee-canary; do
            systemctl --user stop "$svc" 2>/dev/null || true
        done
        for _i in $(seq 1 10); do
            if ! nvidia-smi --query-compute-apps=name --format=csv,noheader 2>/dev/null | grep -qE "transcribe|python"; then
                break
            fi
            sleep 0.5
        done
        # Check if VRAM is sufficient (need ~5 GB for Parakeet + Sortformer)
        if command -v nvidia-smi >/dev/null 2>&1; then
            free_mb=$(nvidia-smi --query-gpu=memory.free --format=csv,noheader,nounits 2>/dev/null | head -1)
            if [ -n "$free_mb" ] && [ "$free_mb" -lt 5120 ]; then
                # Unload ollama models to free VRAM
                if nvidia-smi --query-compute-apps=name --format=csv,noheader 2>/dev/null | grep -q ollama; then
                    ollama_model=$(grep '^DICTEE_OLLAMA_MODEL=' "${XDG_CONFIG_HOME:-$HOME/.config}/dictee.conf" 2>/dev/null | cut -d= -f2)
                    curl -s http://localhost:11434/api/generate -d "{\"model\":\"${ollama_model:-translategemma}\",\"keep_alive\":0}" >/dev/null 2>&1 || true
                    sleep 1
                fi
            fi
        fi
        diarize_file="/tmp/dictee-diarize-$(date +%s).wav"
        cp "$RECORDING_FILE" "$diarize_file"
        rm -f "$ID_TMP_FILE" "$RECORDING_FILE" "$TRANSLATE_BACKEND_FILE" "$TRANSLATE_FLAG_FILE"
        # Launch diarization UI and wait — restore backend when done (even on crash)
        dictee-transcribe --file "$diarize_file" --diarize
        dictee-switch-backend diarize false
        exit 0
    fi

    if ! raw=$(eval transcribe-client "$RECORDING_FILE"); then
        if [ -n "$id" ]; then
            notify-send --replace-id="$id" -t 5000 -i dialog-error -a Dictee "Transcription failed — daemon not responding" 2>/dev/null || true
        else
            notify-send -t 5000 -i dialog-error -a Dictee "Transcription failed — daemon not responding" 2>/dev/null || true
        fi
        write_state "idle"
        rm -f "$RECORDING_FILE" "$TRANSLATE_BACKEND_FILE" "$TRANSLATE_FLAG_FILE"
        exit 1
    fi
    if [ -z "$raw" ]; then
        if [ -n "$id" ]; then
            notify-send --replace-id="$id" -t 5000 -i dialog-error -a Dictee "Transcription failed — empty result" 2>/dev/null || true
        else
            notify-send -t 5000 -i dialog-error -a Dictee "Transcription failed — empty result" 2>/dev/null || true
        fi
        write_state "idle"
        rm -f "$RECORDING_FILE" "$TRANSLATE_BACKEND_FILE" "$TRANSLATE_FLAG_FILE"
        exit 1
    fi
    if [ -n "$SUPPRIME" ]; then
        echo "$raw" | dictee-postprocess > /dev/shm/.dictee_pp
        transcribed=$(cat /dev/shm/.dictee_pp; printf x)
        transcribed="${transcribed%x}"
        rm -f /dev/shm/.dictee_pp
    else
        transcribed="$raw"
    fi

    # Supprimer les espaces de fin (jamais significatifs, évite les doubles espaces
    # quand la continuation ajoute un espace au push suivant)
    transcribed="${transcribed%"${transcribed##*[! ]}"}"

    # Continuation inter-appuis : adapter le texte si phrase précédente incomplète
    apply_continuation transcribed

    if [ "$TRANSLATE" = true ]; then
        # Traduire et copier
        if [ -n "$id" ]; then
            notify-send --replace-id="$id" -t 5000 -i audio-chat-none-symbolic -a Dictee "Traduction en cours..."
        fi

        if [ "$DICTEE_ASR_BACKEND" = "canary" ]; then
            # Canary: built-in translation — single daemon call with target language
            translated=$(transcribe_canary_translate "$RECORDING_FILE" "$LANG_TARGET" 2>/dev/null) || translated=""
            _trans_label="canary"
        else
            translated=$(translate "$transcribed" "$TRANSLATE_BACKEND" 2>/dev/null) || translated=""
            _trans_label="$TRANSLATE_BACKEND"
        fi
        if [ -n "$translated" ]; then
            copy_to_clipboard "$translated"
            type_text "$translated"
            save_last_word "$translated"

            if [ -n "$id" ]; then
                notify-send --replace-id="$id" -t 5000 -i clipboard-paste-symbolic -a Dictee "$LANG_LABEL ($_trans_label):" "<i>\"$transcribed\"</i> → <b>\"$translated\"</b>"
            else
                notify-send -t 5000 -i clipboard-paste-symbolic -a Dictee "$LANG_LABEL ($_trans_label):" "<i>\"$transcribed\"</i> → <b>\"$translated\"</b>"
            fi
        else
            # Traduction échouée — taper le texte original
            copy_to_clipboard "$transcribed"
            type_text "$transcribed"
            save_last_word "$transcribed"

            if [ -n "$id" ]; then
                notify-send --replace-id="$id" -t 5000 -i dialog-warning-symbolic -a Dictee "Traduction échouée ($TRANSLATE_BACKEND)" "<i>\"$transcribed\"</i>"
            else
                notify-send -t 5000 -i dialog-warning-symbolic -a Dictee "Traduction échouée ($TRANSLATE_BACKEND)" "<i>\"$transcribed\"</i>"
            fi
        fi
    else
        # Copier directement
        copy_to_clipboard "$transcribed"
        type_text "$transcribed"
        save_last_word "$transcribed"

        if [ -n "$id" ]; then
            notify-send --replace-id="$id" -t 5000 -i clipboard-paste-symbolic -a Dictee "Texte tapé (${DICTEE_ASR_BACKEND:-parakeet}) :" "<i>\"$transcribed\"</i>"
        else
            notify-send -t 5000 -i clipboard-paste-symbolic -a Dictee "Texte tapé (${DICTEE_ASR_BACKEND:-parakeet}) :" "<i>\"$transcribed\"</i>"
        fi
    fi

    rm -f "$ID_TMP_FILE" "$RECORDING_FILE" "$TRANSLATE_BACKEND_FILE" "$TRANSLATE_FLAG_FILE"
    write_state "idle"

    # Réactiver trap ERR
    trap 'cleanup_on_error $LINENO' INT TERM HUP QUIT ERR

else
    # === DÉMARRAGE DE L'ENREGISTREMENT ===

    # Verrou atomique : empêcher un double-démarrage (rebond clavier, double raccourci)
    exec 201>"${PIDFILE}.lock"
    if ! flock -n 201; then
        exit 0  # un autre dictee est déjà en train de démarrer
    fi

    if [ "$NO_ESC_LISTENER" = false ]; then start_escape_listener; fi

    # Sauvegarder les options choisies
    if [ "$TRANSLATE" = true ]; then
        touch "$TRANSLATE_FLAG_FILE"
        echo "$TRANSLATE_BACKEND" >"$TRANSLATE_BACKEND_FILE"
    fi

    # Vérifier si le micro est muté et le démuter
    if pactl get-source-mute @DEFAULT_SOURCE@ | grep -q -i -E 'oui|yes'; then
        pactl set-source-mute @DEFAULT_SOURCE@ 0
        echo "MUT=1" >"$MUT_FILE"
    fi
    # Muter le son (pour éviter le feedback)
    pactl set-sink-mute @DEFAULT_SINK@ 1

    # Lancer l'animation (si mode speech ou both, et si disponible)
    if [ "$ANIMATION" = "speech" ] || [ "$ANIMATION" = "both" ]; then
        if command -v animation-speech-ctl >/dev/null 2>&1; then
            SCRIPT_PATH="$(readlink -f "$0")"
            if animation-speech-ctl launch --on-escape "$SCRIPT_PATH --cancel" 2>/dev/null; then true; fi
        fi
    fi

    # Démarrer l'enregistrement EN PREMIER (avant notification/plasmoid pour ne rien perdre)
    pw-record --rate 16000 --channels 1 --format s16 "$RECORDING_FILE" &
    echo $! >"$PIDFILE"

    # Vérifier que pw-record a bien démarré
    sleep 0.2
    if ! kill -0 $! 2>/dev/null; then
        rm -f "$PIDFILE" "${PIDFILE}.lock" "$RECORDING_FILE"
        notify-send -t 5000 -i dialog-error -a Dictee "Recording failed — audio device unavailable" 2>/dev/null || true
        write_state "idle"
        exit 1
    fi

    # Signaler au plasmoid
    write_state "recording"

    # Notification (sert aussi de délai pour pw-record)
    if [ "$TRANSLATE" = true ]; then
        if [ "$DICTEE_ASR_BACKEND" = "canary" ]; then
            _rec_trans_label="canary"
        else
            _rec_trans_label="$TRANSLATE_BACKEND"
        fi
        notify-send -p -t 0 -i audio-chat-symbolic -a Dictee "Enregistrement $LANG_LABEL ($_rec_trans_label) (${DICTEE_ASR_BACKEND:-parakeet})" >"$ID_TMP_FILE"
    else
        notify-send -p -t 0 -i audio-chat-symbolic -a Dictee "Enregistrement démarré (${DICTEE_ASR_BACKEND:-parakeet})" >"$ID_TMP_FILE"
    fi
fi
