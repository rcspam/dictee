#!/bin/bash
#
# Dictée vocale - enregistre avec le micro, transcrit et tape le texte
# Optionnellement traduit avant d'envoyer
#
# Backends traduction: trans (défaut), ollama (translategemma)
# Langues configurables via variables d'environnement :
#   DICTEE_LANG_SOURCE (défaut: langue système), DICTEE_LANG_TARGET (défaut: en)
#
# Usage: dictee [--translate] [--ollama] [--cancel] [--setup [--wizard]]
#   dictee                      # transcrit et tape
#   dictee --translate          # transcrit, traduit (trans), tape
#   dictee --translate --ollama # traduit avec ollama/translategemma
#   dictee --cancel             # annule l'enregistrement en cours
#   dictee --setup              # ouvre l'interface de configuration
#   dictee --setup --wizard     # ouvre l'assistant de configuration
#
# Nécessite : transcribe-daemon (en cours), pw-record, dotool
# Optionnel : animation-speech-ctl (https://github.com/rcspam/animation-speech)

# === CONFIGURATION ===

# Load configuration (dictee-setup)
DICTEE_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/dictee.conf"
if [ -f "$DICTEE_CONF" ]; then
    set -a
    source "$DICTEE_CONF"
    set +a
fi

# === COMMON FUNCTIONS ===
_DBG_CONTEXT="dictee"
for _p in "$(dirname "$(readlink -f "$0")")" /usr/lib/dictee; do
    [ -f "$_p/dictee-common.sh" ] && { source "$_p/dictee-common.sh"; break; }
done

# Parse --help before config guard (works without config)
case "${1:-}" in
    --help|-h)
        head -n 18 "$0" | grep '^#' | sed 's/^# \?//'
        exit 0
        ;;
esac

# First-run guard: launch wizard if no config or setup not completed
if [ ! -f "$DICTEE_CONF" ] || ! grep -q "DICTEE_SETUP_DONE=true" "$DICTEE_CONF" 2>/dev/null; then
    exec dictee-setup --wizard
fi

# Export OLLAMA_NUM_GPU if defined in config (forced CPU mode)
[ -n "$OLLAMA_NUM_GPU" ] && export OLLAMA_NUM_GPU

LANG_SOURCE="${DICTEE_LANG_SOURCE:-${LANG%%_*}}"
LANG_TARGET="${DICTEE_LANG_TARGET:-en}"
LANG_LABEL="${LANG_SOURCE^^}→${LANG_TARGET^^}"
CLIPBOARD="${DICTEE_CLIPBOARD:-true}"
ANIMATION="${DICTEE_ANIMATION:-speech}"
# --diarize flag: explicit from plasmoid, F9 never passes it
DIARIZE="false"
for _arg in "$@"; do
    if [ "$_arg" = "--diarize" ]; then DIARIZE="true"; fi
done
AUDIO_SOURCE="${DICTEE_AUDIO_SOURCE:-}"
_dbg "start: args=$* backend=${DICTEE_ASR_BACKEND:-parakeet} diarize=$DIARIZE audio_source=$AUDIO_SOURCE"
# Resolve app:name to numeric PipeWire ID (IDs change after sleep/hibernation)
if [[ "$AUDIO_SOURCE" == app:* ]]; then
    _APP_NAME="${AUDIO_SOURCE#app:}"
    AUDIO_SOURCE=$(pw-dump 2>/dev/null | python3 -c "
import json, sys
for n in json.loads(sys.stdin.read()):
    if n.get('type') != 'PipeWire:Interface:Node': continue
    p = n.get('info', {}).get('props', {})
    if p.get('media.class') == 'Stream/Output/Audio':
        a = p.get('application.name', '').lower().split()
        if a and a[0] == '$_APP_NAME':
            print(n['id']); break
" 2>/dev/null)
    _dbg "resolved app:$_APP_NAME → PipeWire ID ${AUDIO_SOURCE:-NONE}"
fi
# Determine if source is a device (alsa_*) or an application (Firefox, etc.)
# Applications are not pactl sources → mute/unmute on @DEFAULT_SOURCE@
case "$AUDIO_SOURCE" in
    ''|alsa_input.*) _PA_SOURCE="${AUDIO_SOURCE:-@DEFAULT_SOURCE@}"; _IS_APP_SOURCE=false ;;
    *)               _PA_SOURCE="@DEFAULT_SOURCE@"; _IS_APP_SOURCE=true ;;
esac

# Keyboard layout detection for dotool (localectl > setxkbmap > us)
if [ -z "$DOTOOL_XKB_LAYOUT" ]; then
    DOTOOL_XKB_LAYOUT=$(localectl status 2>/dev/null | awk '/X11 Layout/{print $3}')
    [ -z "$DOTOOL_XKB_LAYOUT" ] && DOTOOL_XKB_LAYOUT=$(setxkbmap -query 2>/dev/null | awk '/layout/{print $2}')
    DOTOOL_XKB_LAYOUT="${DOTOOL_XKB_LAYOUT:-us}"
fi
export DOTOOL_XKB_LAYOUT

RECORDING_FILE="$HOME/.cache/tmp_recording_dictee.wav"
PIDFILE="/tmp/recording_dictee_pid${_UID_SUFFIX}"
ID_TMP_FILE="/tmp/notify_dictee${_UID_SUFFIX}"
MUT_FILE="/tmp/mut_dictee${_UID_SUFFIX}"
TRANSLATE_BACKEND_FILE="/tmp/translate_dictee_backend${_UID_SUFFIX}"
TRANSLATE_FLAG_FILE="/tmp/dictee_translate${_UID_SUFFIX}"
DIARIZE_FLAG_FILE="/tmp/dictee_diarize${_UID_SUFFIX}"
LAST_WORD_FILE="/dev/shm/.dictee_last_word"

# Audio context buffer
BUFFER_FILE="/dev/shm/.dictee_buffer${_UID_SUFFIX}.wav"
BUFFER_TS_FILE="/dev/shm/.dictee_buffer_ts${_UID_SUFFIX}"
COMBINED_FILE="/dev/shm/.dictee_combined${_UID_SUFFIX}.wav"
SILENCE_FILE="/dev/shm/.dictee_silence${_UID_SUFFIX}.wav"
SILENCE_DURATION="0.5"
BUFFER_TEXT_FILE="/dev/shm/.dictee_buffer_text${_UID_SUFFIX}"

# === UTILITY FUNCTIONS (script-specific) ===

# Stop the animation (quit or stop)
stop_animation() {
    local cmd="${1:-stop}"
    if [ "$ANIMATION" = "speech" ] || [ "$ANIMATION" = "both" ]; then
        if command -v animation-speech-ctl >/dev/null 2>&1; then
            if animation-speech-ctl "$cmd" 2>/dev/null; then true; fi
        fi
    fi
}

# Restore audio state (re-mute mic if it was muted, unmute sink)
restore_audio() {
    if [ -f "$MUT_FILE" ]; then
        local was_muted=""
        if was_muted=$(awk -F"=" '{print $2}' "$MUT_FILE" 2>/dev/null); then
            if [ "$was_muted" = "1" ]; then
                pactl set-source-mute "$_PA_SOURCE" 1
            fi
        fi
        rm -f "$MUT_FILE"
    fi
    if [ "$_IS_APP_SOURCE" = false ]; then
        pactl set-sink-mute @DEFAULT_SINK@ 0
    fi
}

# Kill the recording process from PIDFILE
# Usage: stop_recording [force]  — "force" adds SIGKILL escalation
stop_recording() {
    if [ ! -f "$PIDFILE" ]; then return; fi
    local rec_pid=""
    rec_pid=$(cat "$PIDFILE" 2>/dev/null) || true
    if [ -n "$rec_pid" ]; then
        if [ "${1:-}" = "force" ]; then
            kill -- -"$rec_pid" 2>/dev/null || kill "$rec_pid" 2>/dev/null
            sleep 0.1
            kill -9 -- -"$rec_pid" 2>/dev/null || kill -9 "$rec_pid" 2>/dev/null
        else
            if kill "$rec_pid" 2>/dev/null; then true; fi
        fi
    fi
    rm -f "$PIDFILE" "${PIDFILE}.lock"
}

# Remove all session temp files
cleanup_session() {
    rm -f "$ID_TMP_FILE" "$RECORDING_FILE" "$TRANSLATE_BACKEND_FILE" "$TRANSLATE_FLAG_FILE" "$DIARIZE_FLAG_FILE"  # ID_TMP_FILE kept for legacy cleanup
    rm -f "$COMBINED_FILE" "$SILENCE_FILE"
}

# Text post-processing (regex rules + dictionary + optional LLM)
if [ "${DICTEE_POSTPROCESS:-true}" = "true" ] && command -v dictee-postprocess >/dev/null 2>&1; then
    SUPPRIME="| dictee-postprocess"
else
    SUPPRIME=""
fi

# Safe dotool wrapper for trap ERR
safe_dotool() {
    if dotool 2>/dev/null; then true; fi
}

# Type text via dotool, with line break handling and sanitization
# dotool does not support: U+00A0, U+202F, …, —, –, tab
# Replace them with ASCII equivalents before sending
type_text() {
    local text="$1"
    # Sanitize unsupported dotool characters (no subshell to preserve \n)
    text="${text//$'\xc2\xa0'/ }"
    text="${text//$'\xe2\x80\xaf'/ }"
    text="${text//$'\xe2\x80\xa6'/...}"
    text="${text//$'\xe2\x80\x94'/--}"
    text="${text//$'\xe2\x80\x93'/-}"
    # Strip \x02 markers (end-of-sentence flag, handled by save_last_word)
    text="${text//$'\x02'/}"
    # Convert to dotool commands: "type ..." + "key enter/tab/ctrl+j" between segments
    # \x01 marker = ctrl+j (newline without submit, from "contrôle j" voice command)
    # & continuation indicator stays in text (typed atomically with the rest)
    printf '%s\n' "$text" | awk -v RS='\n' '{
        if (NR > 1) print "key enter"
        # Split on \x01 (ctrl+j markers)
        nc = split($0, cjparts, "\x01")
        for (c = 1; c <= nc; c++) {
            if (c > 1) print "key ctrl+j"
            # Split on tabs
            n = split(cjparts[c], parts, "\t")
            for (i = 1; i <= n; i++) {
                if (i > 1) print "key tab"
                if (parts[i] != "") printf "type %s\n", parts[i]
            }
        }
    }' | safe_dotool
}

# Cross-push continuation: incomplete sentence detection
# Closed-class words indicating an unfinished sentence — loaded from
# continuation.conf.default (system) + ~/.config/dictee/continuation.conf (user)
load_continuation_words() {
    local file
    for file in "$@"; do
        [ -f "$file" ] || continue
        while IFS= read -r line; do
            line="${line%%#*}"             # remove comments
            line="${line#"${line%%[! ]*}"}" # trim leading whitespace
            [[ "$line" == \[* ]] || continue
            local tag="${line%%]*}"
            tag="${tag#[}"
            # Skip [keyword:*] lines — handled separately
            [[ "$tag" == keyword* ]] && continue
            local words="${line#*]}"
            local var="CONTINUATION_WORDS_${tag^^}"
            # Append words (cumulative)
            eval "${var}=\"\${${var}:-\" \"}\${words} \""
        done < "$file"
    done
}

_SCRIPT_DIR_CONT="$(dirname "$(readlink -f "$0")")"
_SYSTEM_CONT=""
for _c in "$_SCRIPT_DIR_CONT/continuation.conf.default" \
          "/usr/share/dictee/continuation.conf.default" \
          "${XDG_DATA_HOME:-$HOME/.local/share}/dictee/continuation.conf.default"; do
    [ -f "$_c" ] && { _SYSTEM_CONT="$_c"; break; }
done
_USER_CONT="${XDG_CONFIG_HOME:-$HOME/.config}/dictee/continuation.conf"

load_continuation_words ${_SYSTEM_CONT:+"$_SYSTEM_CONT"} ${_USER_CONT:+"$_USER_CONT"}

# Build regex for continuation keyword
# Search order: [keyword:LANG] in user, [keyword:LANG] in system, [keyword] in user, [keyword] in system
_CONT_KEYWORD=""
_LANG_TAG="${LANG_SOURCE:-fr}"
for _pattern in "\\[keyword:${_LANG_TAG}\\]" "\\[keyword\\]"; do
    [ -n "$_CONT_KEYWORD" ] && break
    for _cf in ${_USER_CONT:+"$_USER_CONT"} ${_SYSTEM_CONT:+"$_SYSTEM_CONT"}; do
        [ -f "$_cf" ] || continue
        _match=$(grep -m1 "^\\s*${_pattern}" "$_cf" 2>/dev/null) || continue
        _CONT_KEYWORD="${_match#*] }"
        _CONT_KEYWORD="${_CONT_KEYWORD#"${_CONT_KEYWORD%%[! ]*}"}"
        break 2
    done
done
_CONT_KEYWORD="${_CONT_KEYWORD:-minuscule}"
_CONT_KEYWORD_RE=""
if [ -n "$_CONT_KEYWORD" ]; then
    _kw="${_CONT_KEYWORD,,}"
    # Replace spaces and hyphens with [- ]? to match all variants
    # Use placeholder to avoid double substitution
    _kw="${_kw//-/§}"
    _kw="${_kw// /§}"
    _kw="${_kw//§/[- ]?}"
    # Match is done on ${_ref,,} (lowercase) so no need for [cC] prefix
    # s? tolerates ASR plural ("minuscules")
    _CONT_KEYWORD_RE="^${_kw}s?[.,]?[[:space:]]*(.*)"
    unset _kw
fi

apply_continuation() {
    # Usage: apply_continuation VARNAME
    # Modifies the variable in place (no subshell)
    # Buffer markers:
    #   , → comma (always continuation, space + lowercase)
    #   .N → period(s) (continuation if last word is closed-class, else space + keep case)
    #   F → end of sentence (! ; : » )) — space + keep case
    #   _ → no punctuation (mid-sentence, space + lowercase)
    local -n _ref="$1"
    # If text starts with \n ("new line" voice command), do not modify
    if [[ "$_ref" == $'\n'* ]]; then return; fi
    if [ ! -f "$LAST_WORD_FILE" ]; then return; fi
    local saved
    saved=$(cat "$LAST_WORD_FILE" 2>/dev/null) || return
    local last_char="${saved%%:*}"
    local last_word="${saved#*:}"

    # Hourglass marker: H prefix means ~ was typed instead of punctuation
    # → always 1 backspace to erase it
    local hourglass=false
    if [[ "$last_char" == H* ]]; then
        hourglass=true
        last_char="${last_char#H}"
    fi

    # Helper: send backspaces — 1 if hourglass, else N from marker
    _cont_backspace() {
        local count="${1:-1}"
        # Hourglass: add 1 extra backspace to erase ~
        if $hourglass; then
            count=$((count + 1))
        fi
        local cmd=""
        for ((i=0; i<count; i++)); do
            cmd+="key backspace
"
        done
        printf '%s' "$cmd" | safe_dotool
    }

    # Strip leading spaces (avoid double spaces if previous text
    # had a trailing space, e.g.: "Bonjour, ")
    _ref="${_ref#"${_ref%%[! ]*}"}"

    # Continuation keyword: remove last punctuation + lowercase
    # Configurable via continuation keyword (default: minuscule)
    if [ -n "$_CONT_KEYWORD_RE" ] && [[ "${_ref,,}" =~ $_CONT_KEYWORD_RE ]]; then
        # Match was on lowercase — extract rest from original _ref at same offset
        local matched_len=$(( ${#_ref} - ${#BASH_REMATCH[1]} ))
        local rest="${_ref:matched_len}"
        rest="${rest#"${rest%%[! ]*}"}"
        # Backspace the punctuation (or ~) from the previous push
        if [[ "$last_char" == .* ]]; then
            local bs_count="${last_char#.}"
            _cont_backspace "${bs_count:-1}"
        elif [[ "$last_char" == [,F] ]]; then
            _cont_backspace 1
        fi
        # Set text to rest in lowercase (or empty if nothing follows)
        if [ -n "$rest" ]; then
            _ref=" ${rest,}"
        else
            _ref=""
        fi
        return
    fi

    # If the push starts with punctuation (voice command "comma",
    # "period", etc.), attach it to previous text without space.
    local fc="${_ref:0:1}"
    if [[ "$fc" == [,.\;!?:] ]]; then
        # If previous was a period/punctuation (or ~), erase it
        if [[ "$last_char" == .* ]]; then
            local bs_count="${last_char#.}"
            _cont_backspace "${bs_count:-1}"
        elif [[ "$last_char" == [,F] ]]; then
            _cont_backspace 1
        fi
        # Lowercase only after , ; : (continuation)
        # Keep case after . ! ? (new sentence)
        # Exception: if prefix contains \n (e.g.: ":\n"), it's a new
        # paragraph → keep case (uppercase)
        if [[ "$fc" == [,\;:] ]]; then
            local prefix="${_ref%%[A-Za-zÀ-ÿ]*}"
            if [[ "$prefix" != *$'\n'* ]]; then
                local after="${_ref#"$prefix"}"
                if [ -n "$after" ]; then
                    _ref="${prefix}${after,}"
                fi
            fi
        fi
        return
    fi

    if [ "$last_char" = "," ]; then
        # After comma: always continue (space + lowercase)
        _ref=" ${_ref,}"
    elif [[ "$last_char" == .* ]]; then
        # After period(s): continue only if last word is closed-class
        # Marker format: .N where N = number of backspaces (1, 2, or 3)
        local lower="${last_word,,}"
        local _cw_var="CONTINUATION_WORDS_${LANG_SOURCE^^}"
        local _cw="${!_cw_var}"
        if [[ -n "$_cw" && "$_cw" == *" $lower "* ]]; then
            local bs_count="${last_char#.}"
            _cont_backspace "${bs_count:-1}"
            _ref=" ${_ref,}"
        else
            # Sentence complete: space, keep case
            _ref=" ${_ref}"
        fi
    elif [ "$last_char" = "F" ]; then
        # After ! ? … ; : » ): sentence complete, space + keep case
        _ref=" ${_ref}"
    elif [ "$last_char" = "_" ]; then
        # No punctuation: mid-sentence, space + lowercase
        if $hourglass; then
            # Only erase & (1 backspace), no punctuation to remove
            printf 'key backspace\n' | safe_dotool
        fi
        _ref=" ${_ref,}"
    fi
}

save_last_word() {
    # Save punctuation marker and last word for continuation
    # Markers: , . F (end: ! ? … ; : » )) _ (no punctuation)
    local text="$1"
    # If text contains \n ("new line" voice command),
    # don't save: next push is independent
    if [[ "$text" == *$'\n'* ]]; then
        rm -f "$LAST_WORD_FILE"
        return
    fi
    # \x02 = forced end-of-sentence (from "point suivi" etc.)
    local force_end=false
    if [[ "$text" == *$'\x02'* ]]; then
        force_end=true
        text="${text//$'\x02'/}"
    fi
    # Strip trailing spaces (pure bash, no subshell)
    local trimmed="${text%"${text##*[! ]}"}"
    if [ -z "$trimmed" ]; then
        rm -f "$LAST_WORD_FILE"
        return
    fi

    local marker="" stripped=""

    # Check multi-character patterns first (ellipsis)
    # Marker encodes backspace count: .3 = "...", .2 = "..", .1 = "…" or "."
    if [[ "$trimmed" == *... ]]; then
        marker=".3"
        stripped="${trimmed%...}"
    elif [[ "$trimmed" == *.. ]]; then
        marker=".2"
        stripped="${trimmed%..}"
    elif [[ "$trimmed" == *$'\xe2\x80\xa6' ]]; then
        # … (U+2026) — type_text() converts to "..." (3 ASCII chars) → 3 backspaces
        marker=".3"
        stripped="${trimmed%?}"
    else
        local last_char="${trimmed: -1}"
        stripped="${trimmed%?}"
        case "$last_char" in
            .)  marker=".1" ;;
            ,)  marker="," ;;
            '?')  # French typography adds NNBSP before ? → 2 backspaces; other languages → 1
                if [ "${LANG_SOURCE:-}" = "fr" ]; then marker=".2"; else marker=".1"; fi ;;
            '!')  # Same NNBSP logic for !
                if [ "${LANG_SOURCE:-}" = "fr" ]; then marker=".2"; else marker="F"; fi ;;
            ';'|':'|$'\xbb')  marker="F" ;;
            ')')  marker="F" ;;
            *)  marker="_" ; stripped="$trimmed" ;;
        esac
    fi

    # Extract the last word (before punctuation)
    if [ "$marker" != "_" ]; then
        stripped="${stripped%"${stripped##*[! ]}"}"
    fi
    local last_word="${stripped##* }"
    # Handle hyphenated words: "parles-tu" → check "tu" for continuation
    if [[ "$last_word" == *-* ]]; then
        last_word="${last_word##*-}"
    fi

    # Forced end-of-sentence overrides any marker to F
    if $force_end; then
        marker="F"
    fi

    # If continuation is likely (closed-class word), append & after text
    # (never replace — always append). On next push, backspace & + punctuation.
    # The variable name is passed as $2 (optional, for in-place modification)
    if [ -n "${2:-}" ] && [[ "$marker" == .* || "$marker" == "_" ]] && ! $force_end; then
        local lower="${last_word,,}"
        local _cw_var="CONTINUATION_WORDS_${LANG_SOURCE^^}"
        local _cw="${!_cw_var}"
        if [[ -n "$_cw" && "$_cw" == *" $lower "* ]]; then
            local -n _text_ref="$2"
            _text_ref="${_text_ref}&"
            # Mark as hourglass: H prefix → need extra backspace for ~
            marker="H${marker}"
        fi
    fi

    if [ -n "$last_word" ]; then
        echo "${marker}:${last_word}" > "$LAST_WORD_FILE"
    else
        rm -f "$LAST_WORD_FILE"
    fi
}

# Check if audio context buffer is enabled
audio_context_enabled() {
    [ "${DICTEE_AUDIO_CONTEXT:-false}" = "true" ]
}

# Check if buffer exists and is not expired
buffer_valid() {
    if [ ! -f "$BUFFER_FILE" ] || [ ! -f "$BUFFER_TS_FILE" ]; then
        return 1
    fi
    local ts now timeout
    ts=$(cat "$BUFFER_TS_FILE" 2>/dev/null) || return 1
    now=$(date +%s)
    timeout="${DICTEE_AUDIO_CONTEXT_TIMEOUT:-30}"
    if [ $((now - ts)) -gt "$timeout" ]; then
        _dbg "audio-context: buffer expired (age=$((now - ts))s > ${timeout}s)"
        rm -f "$BUFFER_FILE" "$BUFFER_TS_FILE" "$BUFFER_TEXT_FILE"
        return 1
    fi
    return 0
}

# Trim buffer to max duration (DICTEE_AUDIO_CONTEXT_TIMEOUT seconds)
trim_buffer() {
    local timeout="${DICTEE_AUDIO_CONTEXT_TIMEOUT:-30}"
    local duration
    duration=$(soxi -D "$BUFFER_FILE" 2>/dev/null) || return 0
    local dur_int=${duration%.*}
    if [ "${dur_int:-0}" -gt "$timeout" ]; then
        local offset=$((dur_int - timeout))
        if [ "$offset" -le 0 ]; then
            _dbg "audio-context: trim offset <= 0, skipping"
            return 0
        fi
        _dbg "audio-context: trimming buffer from ${duration}s to ${timeout}s"
        if sox "$BUFFER_FILE" "${BUFFER_FILE}.tmp" trim "=${offset}" 2>/dev/null && [ -s "${BUFFER_FILE}.tmp" ]; then
            mv "${BUFFER_FILE}.tmp" "$BUFFER_FILE"
        else
            rm -f "${BUFFER_FILE}.tmp"
            _dbg "audio-context: WARNING — trim failed, using full buffer"
        fi
    fi
}

# Generate silence WAV (cached)
generate_silence() {
    if [ ! -f "$SILENCE_FILE" ] || [ ! -s "$SILENCE_FILE" ]; then
        rm -f "$SILENCE_FILE"
        if ! sox -n -r 16000 -c 1 -b 16 "$SILENCE_FILE" trim 0.0 "$SILENCE_DURATION" 2>/dev/null || [ ! -s "$SILENCE_FILE" ]; then
            _dbg "audio-context: ERROR — failed to generate silence"
            rm -f "$SILENCE_FILE"
            return 1
        fi
    fi
}

# Get buffer duration in seconds (float)
get_buffer_duration() {
    soxi -D "$BUFFER_FILE" 2>/dev/null
}

# Concatenate buffer + silence + new recording into combined file
build_combined() {
    local recording="$1"
    trim_buffer
    generate_silence || return 1
    _dbg "audio-context: concat buffer + silence + recording"
    if ! sox "$BUFFER_FILE" "$SILENCE_FILE" "$recording" "$COMBINED_FILE" 2>/dev/null || [ ! -s "$COMBINED_FILE" ]; then
        rm -f "$COMBINED_FILE"
        _dbg "audio-context: ERROR — concat failed"
        return 1
    fi
}

# Resolve daemon socket path (same logic as transcribe-client)
_daemon_socket() {
    if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
        echo "${XDG_RUNTIME_DIR}/transcribe.sock"
    else
        echo "/tmp/transcribe-$(id -u).sock"
    fi
}

# Send audio to daemon with timestamps mode, return timestamped lines
transcribe_with_timestamps() {
    local audio_path="$1"
    local sock
    sock=$(_daemon_socket)
    python3 -c "
import socket, sys
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(30)
s.connect(sys.argv[1])
s.sendall((sys.argv[2] + '\ttimestamps\n').encode())
s.shutdown(socket.SHUT_WR)
data = b''
while True:
    chunk = s.recv(4096)
    if not chunk: break
    data += chunk
s.close()
print(data.decode().strip())
" "$sock" "$audio_path"
}

# Extract text from timestamped lines where start >= threshold - margin
# Input format: [0.42s - 1.85s] word
# Margin of 0.5s avoids cutting first words due to timestamp alignment
split_by_timestamp() {
    local timestamped="$1"
    local threshold="$2"
    echo "$timestamped" | python3 -c "
import sys, re
threshold = float(sys.argv[1]) - 0.5
lines = sys.stdin.read().strip().split('\n')
parts = []
for line in lines:
    m = re.match(r'\[(\d+\.\d+)s\s*-\s*\d+\.\d+s\]\s*(.*)', line)
    if m and float(m.group(1)) >= threshold:
        parts.append(m.group(2))
print(' '.join(parts).strip())
" "$threshold"
}

# Save recording as new buffer (only if transcription was non-empty)
save_buffer() {
    local recording="$1"
    cp "$recording" "$BUFFER_FILE"
    date +%s > "$BUFFER_TS_FILE"
    _dbg "audio-context: buffer saved ($(stat -c%s "$BUFFER_FILE") bytes)"
}

# Extract the "new" part from a combined transcription using the solo transcription as guide.
# The combined = [buffer text] + [new text with context-aware homophones].
# The solo = [new text without context].
# Strategy: find where the solo text starts in the combined, return that part from combined.
# Falls back to solo if matching fails.
extract_new_from_combined() {
    local combined_text="$1"
    local solo_text="$2"
    python3 -c "
import re, sys
combined = sys.argv[1]
solo = sys.argv[2]
def norm(s):
    return re.sub(r'[^\w\s]', '', s.lower()).split()
cw = norm(combined)
sw = norm(solo)
if not sw or not cw:
    print(solo)
    sys.exit()
# Find the LAST position in combined where solo starts (skip buffer part)
# Search backwards: the new text is at the end of the combined
best_pos = -1
match_words = min(3, len(sw))
for i in range(len(cw) - match_words, -1, -1):
    matches = sum(1 for j in range(match_words) if cw[i+j] == sw[j])
    if matches >= match_words - 1:  # allow 1 mismatch in first 3 words
        best_pos = i
        break
if best_pos < 0:
    # No match found — solo text not found in combined, use solo (safe)
    print(solo)
else:
    # Return from best_pos onwards in original combined text
    words = combined.split()
    result = ' '.join(words[best_pos:]).strip()
    # Sanity: result should be roughly similar length to solo (±50%)
    if len(result) < len(solo) * 0.5 or len(result) > len(solo) * 1.8:
        print(solo)  # something went wrong, use safe fallback
    else:
        print(result)
" "$combined_text" "$solo_text"
}

# Strip buffer text from the beginning of combined transcription.
# Used by Canary whose proportional timestamps prevent timestamp-based splitting.
# Falls back to full text if stripping fails.
strip_buffer_text() {
    local combined_text="$1"
    local buf_text
    buf_text=$(cat "$BUFFER_TEXT_FILE" 2>/dev/null) || { echo "$combined_text"; return; }
    if [ -z "$buf_text" ]; then echo "$combined_text"; return; fi
    python3 -c "
import re, sys
buf = sys.argv[1]
combined = sys.argv[2]
def norm(s):
    return re.sub(r'[^\w\s]', '', s.lower()).split()
bw = norm(buf)
cw = norm(combined)
if not bw or not cw:
    print(combined)
    sys.exit()
# Find longest prefix match (allowing minor mismatches from retranscription)
n = 0
mismatches = 0
max_mismatches = max(1, len(bw) // 5)  # allow ~20% mismatch
for i in range(min(len(bw), len(cw))):
    if cw[i] == bw[i]:
        n = i + 1
    else:
        mismatches += 1
        if mismatches <= max_mismatches:
            n = i + 1  # skip mismatch, keep going
        else:
            break
# Only strip if we matched at least 60% of buffer words
if n >= len(bw) * 0.6:
    words = combined.split()
    print(' '.join(words[n:]).strip())
else:
    print(combined)
" "$buf_text" "$combined_text"
}

# Parse arguments — dictee.conf values serve as defaults,
# CLI arguments override them.
TRANSLATE_BACKEND="${DICTEE_TRANSLATE_BACKEND:-trans}"
TRANSLATE="${DICTEE_TRANSLATE:-false}"
CANCEL=false

for arg in "$@"; do
    case "$arg" in
    --cancel)
        CANCEL=true
        ;;
    --translate)
        TRANSLATE=true
        ;;
    --ollama)
        TRANSLATE_BACKEND="ollama"
        ;;
    --setup)
        shift
        exec dictee-setup "$@"
        ;;
    --wizard)
        exec dictee-setup --wizard
        ;;
    --help|-h)
        head -n 18 "$0" | grep '^#' | sed 's/^# \?//'
        exit 0
        ;;
    esac
done

# === FUNCTIONS ===

# === CLIPBOARD ===

copy_to_clipboard() {
    [ "$CLIPBOARD" = true ] || return 0
    if command -v wl-copy >/dev/null 2>&1 && [ "$XDG_SESSION_TYPE" = "wayland" ]; then
        echo -n "$1" | wl-copy
    elif command -v xclip >/dev/null 2>&1; then
        echo -n "$1" | xclip -selection clipboard
    elif command -v xsel >/dev/null 2>&1; then
        echo -n "$1" | xsel --clipboard --input
    fi
}

# === DEPENDENCIES ===

check_dependencies() {
    local missing=()
    command -v pw-record >/dev/null || missing+=("pipewire")
    # wl-copy / xclip / xsel is optional (clipboard copy as bonus)
    command -v dotool >/dev/null || missing+=("dotool")
    if ! command -v pactl >/dev/null; then
        missing+=("pulseaudio-utils or pipewire-pulse")
    fi
    command -v notify-send >/dev/null || missing+=("libnotify-bin")

    # Check translation backend if --translate
    if [ "$TRANSLATE" = true ]; then
        if [ "$TRANSLATE_BACKEND" = "trans" ]; then
            command -v trans >/dev/null || missing+=("translate-shell")
        elif [ "$TRANSLATE_BACKEND" = "libretranslate" ]; then
            command -v curl >/dev/null || missing+=("curl")
        elif [ "$TRANSLATE_BACKEND" = "ollama" ]; then
            command -v ollama >/dev/null || missing+=("ollama")
        fi
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        echo "Dépendances manquantes: ${missing[*]}" >&2
        exit 1
    fi
}

cleanup_on_error() {
    local exit_code=$?
    local err_line="${1:-unknown}"
    echo "$(date '+%F %T') ERR exit=$exit_code line=$err_line" >> "/tmp/dictee-error${_UID_SUFFIX}.log"

    stop_recording force
    stop_animation quit
    restore_audio
    notify_dictee 0 audio-chat-none-symbolic "Enregistrement interrompu"
    cleanup_session
    rm -f "$LAST_WORD_FILE" "$COMBINED_FILE"
    rm -f /dev/shm/.dictee_solo_${$}_* /dev/shm/.dictee_comb_${$}_*
    pkill -P $$ 2>/dev/null

    write_state "idle"
    exit $exit_code
}

transcribe() {
    local audio_file="$1"
    eval transcribe-client "$audio_file" $SUPPRIME
}

transcribe_canary_translate() {
    # Send WAV path + target language to Canary daemon via extended protocol
    local audio_file="$1"
    local target_lang="$2"
    local sock_path
    sock_path=$(_daemon_socket)
    printf '%s\tlang:%s\n' "$audio_file" "$target_lang" | \
        python3 -c "
import socket, sys
sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
sock.connect('$sock_path')
sock.sendall(sys.stdin.buffer.read())
data = b''
while True:
    chunk = sock.recv(4096)
    if not chunk:
        break
    data += chunk
sock.close()
sys.stdout.buffer.write(data)
"
}

translate() {
    local text="$1"
    local backend="$2"

    case "$backend" in
    trans)
        local engine="${DICTEE_TRANS_ENGINE:-google}"
        echo "$text" | timeout 15 trans -b -e "$engine" "${LANG_SOURCE}:${LANG_TARGET}"
        ;;
    libretranslate)
        local port="${DICTEE_LIBRETRANSLATE_PORT:-5000}"
        local base_url="http://localhost:${port}"
        # Check that LibreTranslate is reachable and languages are available
        local avail_langs
        if ! avail_langs=$(curl -s --max-time 3 --connect-timeout 2 "${base_url}/languages" 2>/dev/null) || [ -z "$avail_langs" ]; then
            echo "Erreur LibreTranslate: serveur inaccessible sur le port ${port}. Vérifier que le conteneur Docker est démarré et le réseau disponible." >&2
            return 1
        fi
        local missing=""
        if ! echo "$avail_langs" | python3 -c "import json,sys; codes=[l['code'] for l in json.load(sys.stdin)]; sys.exit(0 if '${LANG_SOURCE}' in codes else 1)" 2>/dev/null; then
            missing="${LANG_SOURCE}"
        fi
        if ! echo "$avail_langs" | python3 -c "import json,sys; codes=[l['code'] for l in json.load(sys.stdin)]; sys.exit(0 if '${LANG_TARGET}' in codes else 1)" 2>/dev/null; then
            if [ -n "$missing" ]; then
                missing="${missing}, ${LANG_TARGET}"
            else
                missing="${LANG_TARGET}"
            fi
        fi
        if [ -n "$missing" ]; then
            local supported
            supported=$(echo "$avail_langs" | python3 -c "import json,sys; print(', '.join(l['code'] for l in json.load(sys.stdin)))" 2>/dev/null)
            echo "Erreur LibreTranslate: langue(s) non disponible(s): ${missing} (disponibles: ${supported}). Relancer le conteneur Docker avec --load-only incluant ces langues." >&2
            return 1
        fi
        # Escape text for JSON
        local json_text
        json_text=$(printf '%s' "$text" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')
        local result
        result=$(curl -s --max-time 10 "${base_url}/translate" \
            -H "Content-Type: application/json" \
            -d "{\"q\":${json_text},\"source\":\"${LANG_SOURCE}\",\"target\":\"${LANG_TARGET}\"}")
        if echo "$result" | python3 -c 'import json,sys; d=json.load(sys.stdin); print(d["translatedText"])' 2>/dev/null; then
            :
        else
            echo "Erreur LibreTranslate: $result" >&2
            return 1
        fi
        ;;
    ollama)
        trap - ERR
        local model="${DICTEE_OLLAMA_MODEL:-translategemma}"
        # Check if model is already downloaded
        if ! ollama list 2>/dev/null | grep -q "${model%%:*}"; then
            notify_dictee 0 emblem-downloads "Téléchargement du modèle ${model}…" "Premier lancement, veuillez patienter"
        fi
        local prompt="You are a professional ${LANG_SOURCE} to ${LANG_TARGET} translator. Your goal is to accurately convey the meaning and nuances of the original text while adhering to the target language grammar, vocabulary, and cultural sensitivities.
Produce only the ${LANG_TARGET} translation, without any additional explanations or commentary. Please translate the following text:

${text}"
        # Add :latest only if no explicit tag
        [[ "$model" == *:* ]] || model="${model}:latest"
        # Notify only if model needs loading into VRAM (cold start ~5s)
        if ! ollama ps 2>/dev/null | grep -q "${model%%:*}"; then
            notify_dictee 0 translate-symbolic "Chargement du modèle ${model%%:*}…"
        fi
        local _ollama_result
        _ollama_result=$(python3 - "$model" "$prompt" <<'PYEOF'
import json, urllib.request, sys
model, prompt = sys.argv[1], sys.argv[2]
data = json.dumps({"model": model, "prompt": prompt, "stream": False}).encode()
req = urllib.request.Request("http://localhost:11434/api/generate", data=data, headers={"Content-Type": "application/json"})
resp = json.loads(urllib.request.urlopen(req, timeout=30).read())
print(resp.get("response", "").strip())
PYEOF
        )
        trap 'cleanup_on_error $LINENO' INT TERM HUP QUIT ERR
        echo "$_ollama_result"
        ;;
    *)
        echo "Backend traduction inconnu: $backend" >&2
        return 1
        ;;
    esac
}

# === MAIN ===

check_dependencies
trap 'cleanup_on_error $LINENO' INT TERM HUP QUIT ERR

# === CANCELLATION (idempotent via flock) ===
if [ "$CANCEL" = true ]; then
    trap - ERR
    # If PIDFILE exists but state is still idle, wait briefly for recording to start
    if [ -f "$PIDFILE" ]; then
        for _w in 1 2; do
            _cs=$(cat "$STATE_FILE" 2>/dev/null)
            if [ "$_cs" != "idle" ] && [ "$_cs" != "" ]; then break; fi
            _dbg "cancel: waiting for state (PIDFILE exists, state=$_cs, attempt=$_w)"
            sleep 0.05
        done
    fi
    # Read and lock state atomically
    _cancel_state=""
    (
        flock -n 200 || exit 0          # another cancel holds the lock → no-op
        current=$(cat "$STATE_FILE" 2>/dev/null)
        case "$current" in
            idle|offline|cancelled|"") exit 0 ;;  # nothing to cancel
        esac
        echo "cancelled" > "$STATE_FILE"
        # Output previous state for the parent to use
        echo "$current" >&3
    ) 200>"$STATE_LOCK" 3>/tmp/.dictee_cancel_state_$$ || true
    _cancel_state=$(cat /tmp/.dictee_cancel_state_$$ 2>/dev/null)
    rm -f /tmp/.dictee_cancel_state_$$

    if [ -z "$_cancel_state" ]; then
        _dbg "cancel: nothing to cancel"
        exit 0
    fi

    _dbg "cancel: state was $_cancel_state"

    case "$_cancel_state" in
        preparing|diarize-ready)
            # Diarize preparation — kill switch-backend and restore daemon
            if pkill -f "dictee-switch-backend diarize true" 2>/dev/null; then true; fi
            dictee-switch-backend diarize false 2>/dev/null || true
            notify_dictee 0 audio-chat-none-symbolic "Diarisation annulée"
            ;;
        recording)
            # Active recording — stop it
            stop_animation quit
            restore_audio
            stop_recording
            notify_dictee 0 audio-chat-none-symbolic "Enregistrement annulé"
            cleanup_session
            # If diarize was prepared, restore daemon
            _pre_b=$(grep '^DICTEE_PRE_DIARIZE_BACKEND=' "$DICTEE_CONF" 2>/dev/null | cut -d= -f2)
            if [ -n "$_pre_b" ]; then
                _dbg "cancel: recording had diarize prepared — restoring daemon"
                dictee-switch-backend diarize false 2>/dev/null || true
            else
                write_state "idle"
            fi
            ;;
        diarizing)
            # Diarization in progress — kill processes and restore
            if pkill -f "dictee-transcribe.*--diarize" 2>/dev/null; then true; fi
            if pkill -f "transcribe-diarize" 2>/dev/null; then true; fi
            if pkill -f "diarize-only" 2>/dev/null; then true; fi
            sleep 0.2
            dictee-switch-backend diarize false 2>/dev/null || true
            notify_dictee 0 audio-chat-none-symbolic "Diarisation annulée"
            ;;
        transcribing|switching)
            write_state "idle"
            ;;
    esac
    _dbg "cancel: done"
    (sleep 3; gdbus call --session --dest org.freedesktop.Notifications --object-path /org/freedesktop/Notifications --method org.freedesktop.Notifications.CloseNotification "$NOTIFY_SERVER_ID" >/dev/null 2>&1) &
    exit 0
fi

# Clean up stale PIDFILE if process no longer exists (crash, sleep, etc.)
if [ -f "$PIDFILE" ]; then
    _stale_pid=$(cat "$PIDFILE" 2>/dev/null)
    if [ -z "$_stale_pid" ] || ! kill -0 "$_stale_pid" 2>/dev/null; then
        _dbg "stale PIDFILE: pid=$_stale_pid (dead), cleaning up"
        close_notification
        rm -f "$PIDFILE" "${PIDFILE}.lock" "$MUT_FILE"
        cleanup_session
        write_state "idle"
    fi
fi

if [ -f "$PIDFILE" ]; then
    # === STOP RECORDING ===
    _dbg "stop-recording: pid=$(cat "$PIDFILE" 2>/dev/null) translate=$TRANSLATE diarize=$DIARIZE"
    # Disable trap ERR during this section (too many external commands
    # that can legitimately return non-zero: kill, pactl, ffmpeg, etc.)
    trap - ERR

    # Retrieve options used at startup
    if [ -f "$TRANSLATE_FLAG_FILE" ]; then
        TRANSLATE=true
    fi
    if [ -f "$TRANSLATE_BACKEND_FILE" ]; then
        TRANSLATE_BACKEND=$(cat "$TRANSLATE_BACKEND_FILE")
    fi
    if [ -f "$DIARIZE_FLAG_FILE" ]; then
        DIARIZE=true
        _dbg "stop-recording: diarize flag file found → DIARIZE=true"
    fi
    _dbg "stop-recording: after flags: translate=$TRANSLATE diarize=$DIARIZE"
    stop_animation
    restore_audio
    write_state "transcribing"
    stop_recording

    # Skip transcription if recording is silence (nothing spoken)
    _rms=$(sox "$RECORDING_FILE" -n stat 2>&1 | awk '/RMS.*amplitude/{print $3; exit}')
    if [ -n "$_rms" ] && awk "BEGIN{exit(!($_rms < 0.03))}" 2>/dev/null; then
        _dbg "silence detected (RMS=$_rms) — skipping transcription"
        notify_dictee 0 audio-volume-muted-symbolic "Silence détecté — rien à transcrire"
        _close_id="${NOTIFY_SERVER_ID:-$(cat "$_NOTIFY_SID_FILE" 2>/dev/null)}"
        if [ -n "$_close_id" ]; then
            (sleep 2; gdbus call --session --dest org.freedesktop.Notifications \
                --object-path /org/freedesktop/Notifications \
                --method org.freedesktop.Notifications.CloseNotification "$_close_id" >/dev/null 2>&1) &
        fi
        cleanup_session
        write_state "idle"
        exit 0
    fi

    if [ "$TRANSLATE" = true ]; then
        notify_dictee 0 audio-chat-none-symbolic "Transcription + traduction en cours…"
    else
        notify_dictee 0 audio-chat-none-symbolic "Enregistrement arrêté"
    fi

    # Live diarization: copy WAV and launch dictee-transcribe
    if [ "$DIARIZE" = "true" ]; then
        _dbg "diarize: launching dictee-transcribe"
        write_state "diarizing"
        diarize_file="/tmp/dictee-diarize-$(date +%s).wav"
        cp "$RECORDING_FILE" "$diarize_file"
        cleanup_session
        _dbg "diarize: launching dictee-transcribe --file $diarize_file --diarize"
        systemd-run --user --no-block --collect \
            --unit="dictee-transcribe-$$" \
            dictee-transcribe --file "$diarize_file" --diarize
        exit 0
    fi

    # Determine which file to send to daemon and how
    used_context=false
    if audio_context_enabled && buffer_valid; then
        if build_combined "$RECORDING_FILE"; then
            used_context=true
            _dbg "audio-context: using combined file for transcription"

            # Get time threshold: buffer duration + silence
            buf_dur=$(get_buffer_duration) || buf_dur="0"
            threshold=$(python3 -c "print(float('${buf_dur}') + float('${SILENCE_DURATION}'))")
            _dbg "audio-context: threshold=${threshold}s (buf=${buf_dur}s + silence=${SILENCE_DURATION}s)"

            _backend="${DICTEE_ASR_BACKEND:-parakeet}"
            if [ "$_backend" = "vosk" ]; then
                # Vosk: no timestamps, no context
                _dbg "audio-context: backend vosk has no timestamps, skipping context"
                used_context=false
                rm -f "$COMBINED_FILE"
            elif [ "$_backend" = "canary" ]; then
                # Canary: dual transcription mode
                # 1. Transcribe combined (buffer+silence+new) → context-aware result
                # 2. Transcribe recording alone → safe fallback
                # 3. Extract the new part from the combined using the solo as reference
                _dbg "audio-context: canary dual-transcription mode"
                local _canary_id="${$}_${RANDOM}"
                local _canary_solo="/dev/shm/.dictee_solo_${_canary_id}"
                local _canary_comb="/dev/shm/.dictee_comb_${_canary_id}"
                local solo_text=""
                local combined_text=""
                if eval transcribe-client "$RECORDING_FILE" > "$_canary_solo" 2>/dev/null; then
                    solo_text=$(cat "$_canary_solo")
                fi
                if [ -n "$solo_text" ] && eval transcribe-client "$COMBINED_FILE" > "$_canary_comb" 2>/dev/null; then
                    combined_text=$(cat "$_canary_comb")
                fi
                rm -f "$_canary_solo" "$_canary_comb"
                rm -f "$COMBINED_FILE"
                if [ -n "$combined_text" ] && [ -n "$solo_text" ]; then
                    raw=$(extract_new_from_combined "$combined_text" "$solo_text")
                    _dbg "audio-context: canary extracted ${#raw} chars (solo=${#solo_text}, combined=${#combined_text})"
                    # If extraction failed or is empty, use solo (safe fallback)
                    if [ -z "$raw" ]; then
                        _dbg "audio-context: extraction empty, using solo transcription"
                        raw="$solo_text"
                    fi
                else
                    _dbg "audio-context: canary dual-transcription failed, falling back to direct"
                    used_context=false
                fi
            else
                # Parakeet/Whisper: precise acoustic timestamps — split by timestamp threshold
                _dbg "audio-context: using timestamps mode ($_backend)"
                if ! timestamped=$(transcribe_with_timestamps "$COMBINED_FILE"); then
                    _dbg "audio-context: timestamps transcription failed, falling back to direct"
                    used_context=false
                fi

                if [ "$used_context" = true ]; then
                    rm -f "$COMBINED_FILE"
                    _dbg "audio-context: timestamped result: $(echo "$timestamped" | wc -l) words"
                    if [ -z "$timestamped" ]; then
                        _dbg "audio-context: WARNING — empty result with context, discarding buffer"
                        rm -f "$BUFFER_FILE" "$BUFFER_TS_FILE" "$BUFFER_TEXT_FILE"
                        notify_dictee 0 dialog-error "Transcription failed — empty result"
                        write_state "idle"
                        cleanup_session
                        exit 1
                    fi
                    raw=$(split_by_timestamp "$timestamped" "$threshold")
                    _dbg "audio-context: extracted after threshold: ${#raw} chars"
                fi
            fi
        else
            _dbg "audio-context: concat failed, using recording directly"
        fi
    fi

    # Standard transcription (no context, or non-parakeet fallback)
    if [ "$used_context" != true ]; then
        _dbg "transcribe: sending $RECORDING_FILE to daemon"
        if ! raw=$(eval transcribe-client "$RECORDING_FILE"); then
            _dbg "transcribe: FAILED — daemon not responding"
            notify_dictee 0 dialog-error "Transcription failed — daemon not responding"
            write_state "idle"
            cleanup_session
            exit 1
        fi
    fi
    rm -f "$COMBINED_FILE"
    _dbg "transcribe: raw result=${#raw} chars"
    if [ -z "$raw" ]; then
        _dbg "transcribe: FAILED — empty result"
        if [ "$used_context" = true ]; then
            _dbg "audio-context: WARNING — empty result with context, discarding buffer"
            rm -f "$BUFFER_FILE" "$BUFFER_TS_FILE" "$BUFFER_TEXT_FILE"
        fi
        notify_dictee 0 dialog-error "Transcription failed — empty result"
        write_state "idle"
        cleanup_session
        exit 1
    fi
    if [ -n "$SUPPRIME" ]; then
        echo "$raw" | dictee-postprocess > /dev/shm/.dictee_pp
        transcribed=$(cat /dev/shm/.dictee_pp; printf x)
        transcribed="${transcribed%x}"
        rm -f /dev/shm/.dictee_pp
    else
        transcribed="$raw"
    fi

    # Strip trailing spaces (never significant, avoids double spaces
    # when continuation adds a space on next push)
    transcribed="${transcribed%"${transcribed##*[! ]}"}"

    # Cross-push continuation: adapt text if previous sentence was incomplete
    apply_continuation transcribed

    # Save recording as buffer for next push (only if non-empty transcription)
    if audio_context_enabled && [ -n "$transcribed" ]; then
        save_buffer "$RECORDING_FILE"
        echo "$transcribed" > "$BUFFER_TEXT_FILE"
    fi

    if [ "$TRANSLATE" = true ]; then
        notify_dictee 0 audio-chat-none-symbolic "Traduction en cours..."

        if [ "$DICTEE_ASR_BACKEND" = "canary" ]; then
            translated=$(transcribe_canary_translate "$RECORDING_FILE" "$LANG_TARGET" 2>/dev/null) || translated=""
            _trans_label="canary"
        else
            translated=$(translate "$transcribed" "$TRANSLATE_BACKEND" 2>/dev/null) || translated=""
            _trans_label="$TRANSLATE_BACKEND"
        fi
        if [ -n "$translated" ]; then
            copy_to_clipboard "$translated"
            # Use paste for non-Latin scripts (Cyrillic, Arabic, CJK, etc.)
            # dotool "type" cannot handle these characters, use clipboard paste
            if echo "$translated" | grep -qP '[\p{Cyrillic}\p{Arabic}\p{Han}\p{Hangul}\p{Hiragana}\p{Katakana}\p{Thai}\p{Devanagari}\p{Bengali}\p{Georgian}]'; then
                sleep 0.1
                printf 'key ctrl+V\n' | safe_dotool
            else
                type_text "$translated"
            fi
            save_last_word "$translated"
            notify_dictee 0 clipboard-paste-symbolic "$LANG_LABEL ($_trans_label):" "<i>\"$transcribed\"</i> → <b>\"$translated\"</b>"
        else
            copy_to_clipboard "$transcribed"
            type_text "$transcribed"
            save_last_word "$transcribed"
            notify_dictee 0 dialog-warning-symbolic "Traduction échouée ($TRANSLATE_BACKEND)" "<i>\"$transcribed\"</i>"
        fi
    else
        copy_to_clipboard "$transcribed"
        save_last_word "$transcribed" transcribed
        type_text "$transcribed"
        notify_dictee 0 clipboard-paste-symbolic "Texte tapé (${DICTEE_ASR_BACKEND:-parakeet}) :" "<i>\"$transcribed\"</i>"
    fi

    cleanup_session
    write_state "idle"

    # Auto-close the result notification after 5 seconds
    (sleep 5; gdbus call --session --dest org.freedesktop.Notifications --object-path /org/freedesktop/Notifications --method org.freedesktop.Notifications.CloseNotification "$NOTIFY_SERVER_ID" >/dev/null 2>&1) &

    # Re-enable trap ERR
    trap 'cleanup_on_error $LINENO' INT TERM HUP QUIT ERR

else
    # === START RECORDING ===

    # Check state allows recording (only idle or diarize-ready are valid)
    _current_state=$(cat "$STATE_FILE" 2>/dev/null || true)
    _dbg "start-recording: current_state=$_current_state diarize=$DIARIZE"
    case "$_current_state" in
        idle|"")
            ;;  # OK to record (empty = first boot, no state file yet)
        diarize-ready)
            # Auto-enable diarize when state is diarize-ready (tray/F9 without --diarize flag)
            if [ "$DIARIZE" != "true" ]; then
                _dbg "start-recording: auto-enabling diarize (state=diarize-ready)"
                DIARIZE="true"
            fi
            ;;  # OK to record in diarize mode
        *)
            _dbg "start-recording: BLOCKED (state=$_current_state)"
            exit 0
            ;;
    esac

    # Check daemon is running (skip in diarize mode — daemon is intentionally stopped)
    if [ "$_current_state" != "diarize-ready" ]; then
        _backend="${DICTEE_ASR_BACKEND:-parakeet}"
        _ASR_SERVICE=$(asr_service "$_backend")
        if ! systemctl --user is-active --quiet "$_ASR_SERVICE" 2>/dev/null; then
            _dbg "start-recording: BLOCKED — daemon $_ASR_SERVICE not active"
            trap - ERR
            notify_dictee 0 dialog-error "Daemon $_backend non démarré" "Démarrer le daemon depuis le plasmoid ou lancer : systemctl --user start $_ASR_SERVICE"
            if command -v paplay >/dev/null 2>&1; then
                paplay /usr/share/sounds/freedesktop/stereo/dialog-error.oga &
            fi
            exit 0
        fi
    fi

    # Atomic lock: prevent double-start (key bounce, double shortcut)
    exec 201>"${PIDFILE}.lock"
    if ! flock -n 201; then
        _dbg "start-recording: BLOCKED — lock held by another dictee"
        exit 0  # another dictee is already starting
    fi

    # Save chosen options
    if [ "$TRANSLATE" = true ]; then
        touch "$TRANSLATE_FLAG_FILE"
        echo "$TRANSLATE_BACKEND" >"$TRANSLATE_BACKEND_FILE"
    fi
    if [ "$DIARIZE" = "true" ]; then
        touch "$DIARIZE_FLAG_FILE"
    fi

    # Audio management: no mute if capturing an application (numeric node ID)
    if [ "$_IS_APP_SOURCE" = false ]; then
        # Source = microphone: unmute mic, mute output (anti-feedback)
        if pactl get-source-mute "$_PA_SOURCE" | grep -q -i -E 'oui|yes'; then
            pactl set-source-mute "$_PA_SOURCE" 0
            echo "MUT=1" >"$MUT_FILE"
        fi
        pactl set-sink-mute @DEFAULT_SINK@ 1
    fi

    # Launch animation (if mode speech or both, and if available)
    if [ "$ANIMATION" = "speech" ] || [ "$ANIMATION" = "both" ]; then
        if command -v animation-speech-ctl >/dev/null 2>&1; then
            if animation-speech-ctl launch --on-escape "$(readlink -f "$0") --cancel" 2>/dev/null; then true; fi
        fi
    fi

    # Send notification FIRST and save ID atomically (must be available before
    _dbg "start-recording: source=${AUDIO_SOURCE:-default} app=$_IS_APP_SOURCE translate=$TRANSLATE"
    if [ "$TRANSLATE" = true ]; then
        if [ "$DICTEE_ASR_BACKEND" = "canary" ]; then
            _rec_trans_label="canary"
        else
            _rec_trans_label="$TRANSLATE_BACKEND"
        fi
        notify_dictee_async 0 audio-chat-symbolic "Enregistrement $LANG_LABEL ($_rec_trans_label) (${DICTEE_ASR_BACKEND:-parakeet})"
    else
        notify_dictee_async 0 audio-chat-symbolic "Enregistrement démarré (${DICTEE_ASR_BACKEND:-parakeet})"
    fi

    # Start recording
    if [ -n "$AUDIO_SOURCE" ]; then
        pw-record --target "$AUDIO_SOURCE" --rate 16000 --channels 1 --format s16 "$RECORDING_FILE" &
    else
        pw-record --rate 16000 --channels 1 --format s16 "$RECORDING_FILE" &
    fi
    echo $! >"$PIDFILE"

    # Verify pw-record started successfully
    sleep 0.05
    if ! kill -0 $! 2>/dev/null; then
        _dbg "start-recording: FAILED — pw-record died immediately"
        close_notification
        rm -f "$PIDFILE" "${PIDFILE}.lock" "$RECORDING_FILE"
        cleanup_session
        write_state "idle"
        exit 1
    fi

    # Signal plasmoid
    write_state "recording"
    _dbg "start-recording: OK pid=$(cat "$PIDFILE" 2>/dev/null)"
fi
