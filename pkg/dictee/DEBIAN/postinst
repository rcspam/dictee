#!/bin/bash
set -e

MODEL_DIR="/usr/share/dictee"
TDT_DIR="$MODEL_DIR/tdt"
DIAR_DIR="$MODEL_DIR/sortformer"
NEMOTRON_DIR="$MODEL_DIR/nemotron"

HF_TDT="https://huggingface.co/istupakov/parakeet-tdt-0.6b-v3-onnx/resolve/main"
HF_DIAR="https://huggingface.co/altunenes/parakeet-rs/resolve/main"
HF_NEMOTRON="https://huggingface.co/altunenes/parakeet-rs/resolve/main/nemotron-speech-streaming-en-0.6b"

TDT_FILES=(
    "encoder-model.onnx"
    "encoder-model.onnx.data"
    "decoder_joint-model.onnx"
    "vocab.txt"
)

DIAR_FILES=(
    "diar_streaming_sortformer_4spk-v2.1.onnx"
)

NEMOTRON_FILES=(
    "encoder.onnx"
    "encoder.onnx.data"
    "decoder_joint.onnx"
    "tokenizer.model"
)

download_file() {
    local url="$1"
    local dest="$2"
    if [ ! -f "$dest" ]; then
        echo "Téléchargement de $(basename "$dest")..."
        curl -L --progress-bar -o "$dest" "$url"
    else
        echo "$(basename "$dest") déjà présent."
    fi
}

download_tdt() {
    echo ""
    echo "=== Modèle TDT (transcription multilingue, ~2.5 Go) ==="
    mkdir -p "$TDT_DIR"
    for file in "${TDT_FILES[@]}"; do
        download_file "$HF_TDT/$file" "$TDT_DIR/$file"
    done
}

download_sortformer() {
    echo ""
    echo "=== Modèle Sortformer (diarisation, ~50 Mo) ==="
    mkdir -p "$DIAR_DIR"
    for file in "${DIAR_FILES[@]}"; do
        download_file "$HF_DIAR/$file" "$DIAR_DIR/$file"
    done
}

download_nemotron() {
    echo ""
    echo "=== Modèle Nemotron (streaming anglais, ~2.5 Go) ==="
    mkdir -p "$NEMOTRON_DIR"
    for file in "${NEMOTRON_FILES[@]}"; do
        download_file "$HF_NEMOTRON/$file" "$NEMOTRON_DIR/$file"
    done
}

# Vérifier si les modèles existent déjà
TDT_EXISTS=false
DIAR_EXISTS=false
[ -f "$TDT_DIR/encoder-model.onnx" ] && TDT_EXISTS=true
[ -f "$DIAR_DIR/diar_streaming_sortformer_4spk-v2.1.onnx" ] && DIAR_EXISTS=true

echo ""
echo "=== Installation des modèles Parakeet ==="
echo ""

# Mode interactif si terminal disponible
if [ -t 0 ]; then
    echo "Quels modèles voulez-vous installer ?"
    echo ""
    echo "  1) Tous (recommandé) - TDT + Sortformer + Nemotron (~5 Go)"
    echo "  2) TDT + Sortformer - transcription multilingue + diarisation (~2.6 Go)"
    echo "  3) TDT seul - transcription multilingue (~2.5 Go)"
    echo "  4) Nemotron + Sortformer - streaming anglais + diarisation (~2.6 Go)"
    echo "  5) Aucun - je les installerai manuellement"
    echo ""
    read -p "Choix [1-5, défaut=1]: " choice
    choice=${choice:-1}
else
    # Mode non-interactif : installer tous par défaut
    choice=1
fi

case $choice in
    1)
        download_tdt
        download_sortformer
        download_nemotron
        ;;
    2)
        download_tdt
        download_sortformer
        ;;
    3)
        download_tdt
        ;;
    4)
        download_nemotron
        download_sortformer
        ;;
    5)
        echo "Installation manuelle choisie."
        echo "Téléchargez les modèles depuis :"
        echo "  TDT: https://huggingface.co/istupakov/parakeet-tdt-0.6b-v3-onnx"
        echo "  Sortformer: https://huggingface.co/altunenes/parakeet-rs"
        echo "  Nemotron: https://huggingface.co/altunenes/parakeet-rs/tree/main/nemotron-speech-streaming-en-0.6b"
        echo "Et placez-les dans : $MODEL_DIR"
        ;;
    *)
        echo "Choix invalide, installation par défaut (tous les modèles)"
        download_tdt
        download_sortformer
        download_nemotron
        ;;
esac

# Recharger les services systemd pour les utilisateurs connectés
echo ""
echo "=== Rechargement des services ==="
for uid in $(loginctl list-users --no-legend 2>/dev/null | awk '{print $1}'); do
    user=$(id -nu "$uid" 2>/dev/null) || continue
    if [ -d "/run/user/$uid" ]; then
        echo "→ Rechargement pour $user (uid $uid)"
        sudo -u "$user" XDG_RUNTIME_DIR="/run/user/$uid" DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus" \
            systemctl --user daemon-reload 2>/dev/null || true
    fi
done

echo ""
echo "=== Parakeet Transcribe installé ==="
echo ""
echo "Les services seront activés automatiquement au prochain login."
echo "Pour les activer/désactiver, utilisez : dictee --setup"
echo ""
echo "Assurez-vous que ydotool daemon tourne :"
echo "  systemctl --user enable --now ydotool"
echo ""
echo "Assignez un raccourci clavier à : /usr/bin/dictee"
echo ""
echo "Commandes disponibles :"
echo "  transcribe               - Transcription simple (TDT, multilingue)"
echo "  transcribe-daemon        - Daemon avec modèle préchargé"
echo "  transcribe-client        - Client pour le daemon"
echo "  transcribe-diarize       - Transcription + diarisation (TDT)"
echo "  transcribe-stream-diarize - Streaming + diarisation (Nemotron, anglais)"
echo "  dictee                   - Push-to-talk avec ydotool"
echo ""

exit 0
