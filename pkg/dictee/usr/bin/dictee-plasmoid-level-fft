#!/usr/bin/env python3
"""dictee-plasmoid-level-fft — FFT spectrum analyzer for dictee plasmoid.
Reads raw s16le mono 16kHz PCM from stdin, writes N frequency band levels to a file.
Usage: parec ... | dictee-plasmoid-level-fft N /dev/shm/.dictee_audio_bands
"""
import sys, os, tempfile
import numpy as np

NOISE_CACHE = os.path.expanduser("~/.cache/dictee/noise_floor")

def load_noise_floor(n_bars):
    """Charge le bruit de fond depuis le cache persistant."""
    try:
        vals = np.loadtxt(NOISE_CACHE, dtype=np.float32)
        if len(vals) == n_bars:
            return vals
    except Exception:
        pass
    return None

def save_noise_floor(noise_floor):
    """Sauvegarde le bruit de fond dans le cache persistant."""
    os.makedirs(os.path.dirname(NOISE_CACHE), exist_ok=True)
    np.savetxt(NOISE_CACHE, noise_floor, fmt="%.6f")

def calibrate(n_bars, n_frames=10):
    """Enregistre n_frames de silence et sauvegarde le bruit de fond."""
    import subprocess
    RATE = 16000
    CHUNK = 640
    freq_lo, freq_hi = 80.0, 4000.0
    limits = [int(freq_lo * (freq_hi / freq_lo) ** (i / n_bars) * CHUNK / RATE)
              for i in range(n_bars + 1)]
    hann = np.hanning(CHUNK).astype(np.float32)

    proc = subprocess.Popen(
        ["parec", "--rate=16000", "--channels=1", "--format=s16le", "--latency-msec=40"],
        stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)

    frames = []
    for _ in range(n_frames):
        data = proc.stdout.read(CHUNK * 2)
        if len(data) < CHUNK * 2:
            break
        samples = np.frombuffer(data, dtype=np.int16).astype(np.float32)
        spectrum = np.abs(np.fft.rfft(samples * hann))
        bands = np.zeros(n_bars, dtype=np.float32)
        for b in range(n_bars):
            lo = max(1, limits[b])
            hi = min(max(lo + 1, limits[b + 1]), len(spectrum))
            if lo < hi:
                chunk = spectrum[lo:hi]
                bands[b] = (np.sqrt(np.mean(chunk ** 2)) * 0.6 + np.max(chunk) * 0.4) / 32768.0
        frames.append(bands)

    proc.terminate()
    proc.wait()

    noise_floor = np.mean(frames, axis=0) * 1.2
    save_noise_floor(noise_floor)
    print(f"Calibration OK ({n_frames} frames, {n_bars} bandes) → {NOISE_CACHE}")


def main():
    # Mode calibration : dictee-plasmoid-level-fft --calibrate N
    if len(sys.argv) >= 3 and sys.argv[1] == "--calibrate":
        calibrate(int(sys.argv[2]))
        return

    if len(sys.argv) < 3:
        print("Usage: dictee-plasmoid-level-fft N output_file", file=sys.stderr)
        print("       dictee-plasmoid-level-fft --calibrate N", file=sys.stderr)
        sys.exit(1)

    N_BARS = int(sys.argv[1])
    OUT = sys.argv[2]
    RATE = 16000
    CHUNK = 640  # 40ms

    # Limites de frequences log entre 80 Hz et 4000 Hz (plage vocale)
    freq_lo, freq_hi = 80.0, 4000.0
    limits = [int(freq_lo * (freq_hi / freq_lo) ** (i / N_BARS) * CHUNK / RATE)
              for i in range(N_BARS + 1)]

    hann = np.hanning(CHUNK).astype(np.float32)
    prev = np.zeros(N_BARS, dtype=np.float32)

    # Lissage different par bande : basses = plus lisse, aigus = plus reactif
    smooth_prev = np.linspace(0.35, 0.05, N_BARS).astype(np.float32)
    smooth_new = 1.0 - smooth_prev

    # Charger le bruit de fond depuis le cache (pas de calibration auto)
    noise_floor = load_noise_floor(N_BARS)
    if noise_floor is None:
        noise_floor = np.zeros(N_BARS, dtype=np.float32)

    # RNG pour micro-variation
    rng = np.random.default_rng(42)

    while True:
        data = sys.stdin.buffer.read(CHUNK * 2)
        if len(data) < CHUNK * 2:
            break

        samples = np.frombuffer(data, dtype=np.int16).astype(np.float32)
        windowed = samples * hann
        spectrum = np.abs(np.fft.rfft(windowed))

        bands = np.zeros(N_BARS, dtype=np.float32)
        for b in range(N_BARS):
            lo = max(1, limits[b])
            hi = max(lo + 1, limits[b + 1])
            hi = min(hi, len(spectrum))
            if lo < hi:
                chunk = spectrum[lo:hi]
                bands[b] = (np.sqrt(np.mean(chunk ** 2)) * 0.6 + np.max(chunk) * 0.4) / 32768.0

        # Soustraire le bruit de fond (zéro si pas de calibration)
        clean = np.maximum(0, bands - noise_floor)

        # Normalisation adaptative par bande
        normalized = np.zeros(N_BARS, dtype=np.float32)
        for b in range(N_BARS):
            if noise_floor[b] > 1e-6:
                normalized[b] = min(1.0, clean[b] / (noise_floor[b] * 5.0))
            elif clean[b] > 0:
                normalized[b] = min(1.0, clean[b] * 10.0)

        # Micro-variation proportionnelle au signal (decorrelation visuelle)
        jitter = rng.uniform(-0.1, 0.1, N_BARS).astype(np.float32)
        normalized = np.clip(normalized + normalized * jitter, 0, 1)

        # Lissage temporel differencie par bande
        normalized = prev * smooth_prev + normalized * smooth_new
        prev = normalized.copy()

        atomic_write(OUT, " ".join(f"{v:.3f}" for v in normalized))


def atomic_write(path, data):
    fd, tmp = tempfile.mkstemp(dir=os.path.dirname(path))
    os.write(fd, data.encode())
    os.close(fd)
    os.rename(tmp, path)


if __name__ == "__main__":
    main()
