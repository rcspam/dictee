#!/bin/bash
#
# Voice Dictation - records with mic, transcribes and types text
# Optionally translates before typing
#
# Translation backends: trans (default), ollama, libretranslate
# Configurable via environment variables or dictee.conf:
#   DICTEE_LANG_SOURCE (default: system language), DICTEE_LANG_TARGET (default: en)
#
# Usage: dictee [--translate] [--ollama] [--cancel] [--setup]
#   dictee                      # transcribe and type
#   dictee --translate          # transcribe, translate (trans), type
#   dictee --translate --ollama # translate with ollama
#   dictee --cancel             # cancel current recording
#   dictee --setup              # open configuration interface
#
# Requires: transcribe-daemon (running), pw-record, dotool
# Optional: animation-speech-ctl

# === CONFIGURATION ===

# Load configuration (dictee-setup)
DICTEE_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/dictee.conf"
[ -f "$DICTEE_CONF" ] && source "$DICTEE_CONF"

# Export OLLAMA_NUM_GPU if defined in config (forced CPU mode)
[ -n "$OLLAMA_NUM_GPU" ] && export OLLAMA_NUM_GPU

LANG_SOURCE="${DICTEE_LANG_SOURCE:-${LANG%%_*}}"
LANG_TARGET="${DICTEE_LANG_TARGET:-en}"
LANG_LABEL="${LANG_SOURCE^^}→${LANG_TARGET^^}"
CLIPBOARD="${DICTEE_CLIPBOARD:-true}"
ANIMATION="${DICTEE_ANIMATION:-speech}"

# Keyboard layout detection for dotool (localectl > setxkbmap > us)
if [ -z "$DOTOOL_XKB_LAYOUT" ]; then
    DOTOOL_XKB_LAYOUT=$(localectl status 2>/dev/null | awk '/X11 Layout/{print $3}')
    [ -z "$DOTOOL_XKB_LAYOUT" ] && DOTOOL_XKB_LAYOUT=$(setxkbmap -query 2>/dev/null | awk '/layout/{print $2}')
    DOTOOL_XKB_LAYOUT="${DOTOOL_XKB_LAYOUT:-us}"
fi
export DOTOOL_XKB_LAYOUT

RECORDING_FILE="$HOME/.cache/tmp_recording_dictee.mp3"
PIDFILE="/tmp/recording_dictee_pid"
ID_TMP_FILE="/tmp/notify_dictee"
MUT_FILE="/tmp/mut_dictee"
TRANSLATE_BACKEND_FILE="/tmp/translate_dictee_backend"
TRANSLATE_FLAG_FILE="/tmp/dictee_translate"

# Text post-processing (French dictation commands, can be extended)
POINT_A_LA_LIGNE="| sed -E 's/[,.]?point à la ligne[,.]?/.\n/Ig' | sed -E 's/^\.?//g'"
TROIS_PETITS_POINTS="| sed -E 's/(trois|3) petits points/\.\.\./Ig'"
SUPPRIME="${POINT_A_LA_LIGNE} ${TROIS_PETITS_POINTS}"

# Parse arguments — dictee.conf values are defaults, CLI args override them.
TRANSLATE_BACKEND="${DICTEE_TRANSLATE_BACKEND:-trans}"
TRANSLATE="${DICTEE_TRANSLATE:-false}"
CANCEL=false

for arg in "$@"; do
    case "$arg" in
    --cancel)
        CANCEL=true
        ;;
    --translate)
        TRANSLATE=true
        ;;
    --ollama)
        TRANSLATE_BACKEND="ollama"
        ;;
    --setup)
        exec dictee-setup
        ;;
    --help|-h)
        head -n 18 "$0" | grep '^#' | sed 's/^# \?//'
        exit 0
        ;;
    esac
done

# === FUNCTIONS ===

# === ESCAPE LISTENER (/dev/input) ===

ESC_LISTENER_PIDFILE="/tmp/dictee_esc_listener_pid"

start_escape_listener() {
    # Launches a background listener that reads /dev/input to detect ESC
    # Listens to all keyboards simultaneously. Requires 'input' group.
    stop_escape_listener
    # Find all physical keyboards (sysrq+kbd = real keyboard, exclude virtual)
    local kbd_devs
    kbd_devs=$(awk -f <(cat << 'AWKEOF'
/^N:/ { name = $0 }
/^H:.*sysrq.*kbd/ {
    if (name !~ /virtual|Virtual|uinput/) {
        match($0, /event[0-9]+/)
        if (RSTART) print "/dev/input/" substr($0, RSTART, RLENGTH)
    }
}
AWKEOF
    ) /proc/bus/input/devices)
    [ -z "$kbd_devs" ] && return
    local self_path
    self_path="$(readlink -f "$0")"
    nohup python3 -c "
import struct, subprocess, signal, select, os
signal.signal(signal.SIGTERM, lambda *_: exit(0))
devs = '''$kbd_devs'''.strip().split('\n')
fds = []
for d in devs:
    try:
        fds.append(open(d, 'rb'))
    except (PermissionError, FileNotFoundError):
        pass
if not fds:
    exit(1)
while True:
    ready, _, _ = select.select(fds, [], [])
    for f in ready:
        data = f.read(24)
        if len(data) < 24:
            continue
        _s, _u, t, code, val = struct.unpack('llHHi', data)
        if t == 1 and code == 1 and val == 1:
            for ff in fds:
                ff.close()
            subprocess.Popen(['$self_path', '--cancel'])
            exit(0)
" >/dev/null 2>&1 &
    echo $! > "$ESC_LISTENER_PIDFILE"
    disown $!
}

stop_escape_listener() {
    if [ -f "$ESC_LISTENER_PIDFILE" ]; then
        local pid
        pid=$(cat "$ESC_LISTENER_PIDFILE" 2>/dev/null)
        if [ -n "$pid" ]; then
            kill "$pid" 2>/dev/null
            pkill -P "$pid" 2>/dev/null
        fi
        rm -f "$ESC_LISTENER_PIDFILE"
    fi
}

# === DEPENDENCIES ===

check_dependencies() {
    local missing=()
    command -v pw-record >/dev/null || missing+=("pipewire")
    # wl-copy is optional (clipboard sync)
    command -v dotool >/dev/null || missing+=("dotool")
    command -v pactl >/dev/null || missing+=("pulseaudio-utils")
    command -v notify-send >/dev/null || missing+=("libnotify-bin")

    # Check translation backend if --translate
    if [ "$TRANSLATE" = true ]; then
        if [ "$TRANSLATE_BACKEND" = "trans" ]; then
            command -v trans >/dev/null || missing+=("translate-shell")
        elif [ "$TRANSLATE_BACKEND" = "libretranslate" ]; then
            command -v curl >/dev/null || missing+=("curl")
        elif [ "$TRANSLATE_BACKEND" = "ollama" ]; then
            command -v ollama >/dev/null || missing+=("ollama")
        fi
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        echo "Missing dependencies: ${missing[*]}" >&2
        exit 1
    fi
}

cleanup_on_error() {
    local exit_code=$?

    stop_escape_listener

    # Kill pw-record and children
    if [ -f "$PIDFILE" ]; then
        local rec_pid=$(cat "$PIDFILE")
        kill -- -"$rec_pid" 2>/dev/null || kill "$rec_pid" 2>/dev/null
        sleep 0.1
        kill -9 -- -"$rec_pid" 2>/dev/null || kill -9 "$rec_pid" 2>/dev/null
        rm -f "$PIDFILE"
    fi

    # Stop animation
    if [ "$ANIMATION" = "speech" ] || [ "$ANIMATION" = "both" ]; then
        if command -v animation-speech-ctl >/dev/null 2>&1; then
            animation-speech-ctl quit 2>/dev/null
        fi
    fi

    # Kill remaining children
    pkill -P $$ 2>/dev/null

    # Restore audio state
    pactl set-sink-mute @DEFAULT_SINK@ 0
    if [ -f "$MUT_FILE" ]; then
        [[ $(awk -F"=" '{print $2}' "$MUT_FILE") == 1 ]] && pactl set-source-mute @DEFAULT_SOURCE@ 1
        rm -f "$MUT_FILE"
    fi

    # Close persistent notification
    local id=$(cat "$ID_TMP_FILE" 2>/dev/null)
    if [ -n "$id" ]; then
        notify-send --replace-id="$id" -t 3000 -i audio-chat-none-symbolic -a Dictee "Recording interrupted"
    fi

    rm -f "$ID_TMP_FILE" "$RECORDING_FILE" "$TRANSLATE_BACKEND_FILE" "$TRANSLATE_FLAG_FILE"

    exit $exit_code
}

transcribe() {
    local audio_file="$1"
    eval transcribe-client "$audio_file" $SUPPRIME
}

translate() {
    local text="$1"
    local backend="$2"

    case "$backend" in
    trans)
        local engine="${DICTEE_TRANS_ENGINE:-google}"
        echo "$text" | trans -b -e "$engine" "${LANG_SOURCE}:${LANG_TARGET}"
        ;;
    libretranslate)
        local port="${DICTEE_LIBRETRANSLATE_PORT:-5000}"
        local url="http://localhost:${port}/translate"
        # Escape text for JSON
        local json_text
        json_text=$(printf '%s' "$text" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')
        local result
        result=$(curl -s --max-time 10 "$url" \
            -H "Content-Type: application/json" \
            -d "{\"q\":${json_text},\"source\":\"${LANG_SOURCE}\",\"target\":\"${LANG_TARGET}\"}")
        if echo "$result" | python3 -c 'import json,sys; d=json.load(sys.stdin); print(d["translatedText"])' 2>/dev/null; then
            :
        else
            echo "LibreTranslate Error: $result" >&2
            exit 1
        fi
        ;;
    ollama)
        local model="${DICTEE_OLLAMA_MODEL:-translategemma}"
        # Check if model is downloaded
        if ! ollama list 2>/dev/null | grep -q "${model%%:*}"; then
            notify-send -t 0 -i emblem-downloads -a Dictee "Downloading model ${model}..." "Initial launch, please wait"
        fi
        local prompt="You are a professional ${LANG_SOURCE} to ${LANG_TARGET} translator. Your goal is to accurately convey the meaning and nuances of the original text while adhering to the target language grammar, vocabulary, and cultural sensitivities.
Produce only the ${LANG_TARGET} translation, without any additional explanations or commentary. Please translate the following text:

${text}"
        # Add :latest only if no explicit tag
        [[ "$model" == *:* ]] || model="${model}:latest"
        ollama run "$model" "$prompt" 2>/dev/null
        ;;
    *)
        echo "Unknown translation backend: $backend" >&2
        exit 1
        ;;
    esac
}

# === MAIN ===

check_dependencies
trap cleanup_on_error INT TERM HUP QUIT ERR

# === CANCELLATION ===
if [ "$CANCEL" = true ]; then
    if [ -f "$PIDFILE" ]; then
        # Signal to plasmoid
        echo "cancelled" > /dev/shm/.dictee_state 2>/dev/null

        id=$(cat "$ID_TMP_FILE" 2>/dev/null)

        stop_escape_listener

        # Stop animation
        if [ "$ANIMATION" = "speech" ] || [ "$ANIMATION" = "both" ]; then
            if command -v animation-speech-ctl >/dev/null 2>&1; then
                animation-speech-ctl quit 2>/dev/null
            fi
        fi

        # Restore mic state
        if [ -f "$MUT_FILE" ]; then
            [[ $(awk -F"=" '{print $2}' "$MUT_FILE") == 1 ]] && pactl set-source-mute @DEFAULT_SOURCE@ 1
            rm -f "$MUT_FILE"
        fi
        pactl set-sink-mute @DEFAULT_SINK@ 0

        # Stop recording
        kill "$(cat "$PIDFILE")" 2>/dev/null
        rm -f "$PIDFILE"

        if [ -n "$id" ]; then
            notify-send --replace-id="$id" -t 3000 -i audio-chat-none-symbolic -a Dictee "Recording cancelled"
        else
            notify-send -t 3000 -i audio-chat-none-symbolic -a Dictee "Recording cancelled"
        fi
        rm -f "$ID_TMP_FILE" "$RECORDING_FILE" "$TRANSLATE_BACKEND_FILE" "$TRANSLATE_FLAG_FILE"
    fi
    exit 0
fi

if [ -f "$PIDFILE" ]; then
    # === STOP RECORDING ===

    stop_escape_listener

    # Retrieve options used at start
    if [ -f "$TRANSLATE_FLAG_FILE" ]; then
        TRANSLATE=true
    fi
    if [ -f "$TRANSLATE_BACKEND_FILE" ]; then
        TRANSLATE_BACKEND=$(cat "$TRANSLATE_BACKEND_FILE")
    fi

    id=$(cat "$ID_TMP_FILE" 2>/dev/null)

    # Stop animation
    if [ "$ANIMATION" = "speech" ] || [ "$ANIMATION" = "both" ]; then
        if command -v animation-speech-ctl >/dev/null 2>&1; then
            animation-speech-ctl stop 2>/dev/null
        fi
    fi

    # Restore mic state
    if [ -f "$MUT_FILE" ]; then
        [[ $(awk -F"=" '{print $2}' "$MUT_FILE") == 1 ]] && pactl set-source-mute @DEFAULT_SOURCE@ 1
        rm -f "$MUT_FILE"
    fi
    # Unmute sound
    pactl set-sink-mute @DEFAULT_SINK@ 0

    # Signal to plasmoid
    echo "transcribing" > /dev/shm/.dictee_state 2>/dev/null

    # Stop recording
    kill "$(cat "$PIDFILE")" 2>/dev/null
    rm -f "$PIDFILE"

    if [ -n "$id" ]; then
        notify-send --replace-id="$id" -t 30000 -i audio-chat-none-symbolic -a Dictee "Recording stopped"
    fi

    # Transcribe
    transcribed=$(transcribe "$RECORDING_FILE")

    if [ "$TRANSLATE" = true ]; then
        # Translate and paste
        if [ -n "$id" ]; then
            notify-send --replace-id="$id" -t 30000 -i audio-chat-none-symbolic -a Dictee "Translation in progress..."
        fi

        translated=$(translate "$transcribed" "$TRANSLATE_BACKEND")
        if [ "$CLIPBOARD" = true ] && command -v wl-copy >/dev/null; then
            echo "$translated" | wl-copy
            # Small delay to ensure focus is back to target window
            sleep 0.2
            # Use Shift+Insert for reliable "Paste" across Terminals and GUI apps
            printf 'key shift+insert' | dotool 2>/dev/null
        else
            printf 'type %s' "$translated" | dotool 2>/dev/null
        fi

        if [ -n "$id" ]; then
            notify-send --replace-id="$id" -t 5000 -i clipboard-paste-symbolic -a Dictee "$LANG_LABEL ($TRANSLATE_BACKEND):" "<i>\"$transcribed\"</i> → <b>\"$translated\"</b>"
        else
            notify-send -t 5000 -i clipboard-paste-symbolic -a Dictee "$LANG_LABEL ($TRANSLATE_BACKEND):" "<i>\"$transcribed\"</i> → <b>\"$translated\"</b>"
        fi
    else
        # Copy directly
        if [ "$CLIPBOARD" = true ] && command -v wl-copy >/dev/null; then
            echo "$transcribed" | wl-copy
            # Small delay to ensure focus is back to target window
            sleep 0.2
            # Use Shift+Insert for reliable "Paste" across Terminals and GUI apps
            printf 'key shift+insert' | dotool 2>/dev/null
        else
            printf 'type %s' "$transcribed" | dotool 2>/dev/null
        fi

        if [ -n "$id" ]; then
            notify-send --replace-id="$id" -t 5000 -i clipboard-paste-symbolic -a Dictee "Typed text:" "<i>\"$transcribed\"</i>"
        else
            notify-send -t 5000 -i clipboard-paste-symbolic -a Dictee "Typed text:" "<i>\"$transcribed\"</i>"
        fi
    fi

    rm -f "$ID_TMP_FILE" "$RECORDING_FILE" "$TRANSLATE_BACKEND_FILE" "$TRANSLATE_FLAG_FILE"
    echo "idle" > /dev/shm/.dictee_state 2>/dev/null

else
    # === START RECORDING ===

    start_escape_listener

    # Save chosen options
    if [ "$TRANSLATE" = true ]; then
        touch "$TRANSLATE_FLAG_FILE"
        echo "$TRANSLATE_BACKEND" >"$TRANSLATE_BACKEND_FILE"
    fi

    # Check if mic is muted and unmute
    if pactl get-source-mute @DEFAULT_SOURCE@ | grep -q -i -E 'oui|yes'; then
        pactl set-source-mute @DEFAULT_SOURCE@ 0
        echo "MUT=1" >"$MUT_FILE"
    fi
    # Mute sound (avoid feedback)
    pactl set-sink-mute @DEFAULT_SINK@ 1

    # Launch animation
    if [ "$ANIMATION" = "speech" ] || [ "$ANIMATION" = "both" ]; then
        if command -v animation-speech-ctl >/dev/null 2>&1; then
            SCRIPT_PATH="$(readlink -f "$0")"
            animation-speech-ctl launch --on-escape "$SCRIPT_PATH --cancel" 2>/dev/null
        fi
    fi

    # Signal to plasmoid
    echo "recording" > /dev/shm/.dictee_state 2>/dev/null

    # Start recording
    pw-record --rate 16000 --channels 1 --format s16 "$RECORDING_FILE" &
    echo $! >"$PIDFILE"

    # Notification
    if [ "$TRANSLATE" = true ]; then
        notify-send -p -t 0 -i audio-chat-symbolic -a Dictee "Recording $LANG_LABEL ($TRANSLATE_BACKEND)" >"$ID_TMP_FILE"
    else
        notify-send -p -t 0 -i audio-chat-symbolic -a Dictee "Recording started" >"$ID_TMP_FILE"
    fi
fi
