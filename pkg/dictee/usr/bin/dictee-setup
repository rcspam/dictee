        btn_apply = Gtk.Button(label=_("Apply"))
        btn_apply.get_style_context().add_class("suggested-action")
        btn_apply.connect("clicked", self._on_apply)
        box_buttons.pack_start(btn_apply, False, False, 0)

    @staticmethod
    def _system_lang():
        lang = os.environ.get("LANG", "")
        if lang:
            return lang.split("_")[0].split(".")[0]
        try:
            return locale.getdefaultlocale()[0].split("_")[0]
        except (AttributeError, IndexError):
            return "fr"

    def _on_translate_toggled(self, widget):
        self.box_tr_opts.set_sensitive(widget.get_active())

    # -- Systemd services --

    @staticmethod
    def _is_service_enabled(name):
        """Check if a user service is enabled."""
        try:
            result = subprocess.run(
                ["systemctl", "--user", "is-enabled", name],
                capture_output=True, text=True,
            )
            return result.stdout.strip() == "enabled"
        except FileNotFoundError:
            return False

    @staticmethod
    def _set_service(name, enable):
        """Enable/disable and start/stop a user service."""
        action = "enable" if enable else "disable"
        subprocess.run(
            ["systemctl", "--user", action, "--now", name],
            capture_output=True,
        )

    # -- Shortcut capture --

    def _on_capture_clicked(self, _widget):
        self.btn_capture.set_label(_("Press a key combination…"))
        self.lbl_conflict.hide()
        self._capture_handler = self.connect("key-press-event", self._on_key_captured)

    def _on_key_captured(self, _widget, event):
        keyval = event.keyval
        state = event.state & (
            Gdk.ModifierType.CONTROL_MASK
            | Gdk.ModifierType.SHIFT_MASK
            | Gdk.ModifierType.MOD1_MASK  # Alt
            | Gdk.ModifierType.SUPER_MASK
        )

        if keyval in (
            Gdk.KEY_Shift_L, Gdk.KEY_Shift_R,
            Gdk.KEY_Control_L, Gdk.KEY_Control_R,
            Gdk.KEY_Alt_L, Gdk.KEY_Alt_R,
            Gdk.KEY_Super_L, Gdk.KEY_Super_R,
            Gdk.KEY_Meta_L, Gdk.KEY_Meta_R,
            Gdk.KEY_ISO_Level3_Shift,
        ):
            return False

        self.disconnect(self._capture_handler)

        accel = Gtk.accelerator_name(keyval, state)
        label = Gtk.accelerator_get_label(keyval, state)
        self.captured_accel = accel
        self.btn_capture.set_label(_("Shortcut: {label}").format(label=label))

        if self.de_type == "kde":
            conflict = check_kde_conflict(gtk_accel_to_kde(accel))
            if conflict:
                self.lbl_conflict.set_markup(
                    '<span foreground="orange">'
                    + _("Shortcut already used by '{name}'").format(name=conflict)
                    + "</span>"
                )
                self.lbl_conflict.show()
            else:
                self.lbl_conflict.hide()

        return True

    # -- Animation --

    @staticmethod
    def _is_animation_speech_installed():
        """Check if animation-speech-ctl is installed."""
        return shutil.which(ANIMATION_SPEECH_BIN) is not None

    @staticmethod
    def _is_plasmoid_installed():
        """Check if the Dictee plasmoid is installed."""
        try:
            result = subprocess.run(
                ["kpackagetool6", "-t", "Plasma/Applet", "-l"],
                capture_output=True, text=True,
            )
            return "com.github.rcspam.dictee" in result.stdout
        except FileNotFoundError:
            return False

    def _on_anim_mode_changed(self, _widget):
        self._update_anim_availability()

    def _update_anim_availability(self):
        """Update visibility of warnings and install buttons based on mode."""
        mode = self.combo_anim.get_active_id() or "speech"
        has_speech = self._is_animation_speech_installed()
        has_plasmoid = self._is_plasmoid_installed()

        # Status line
        parts = []
        if has_speech:
            parts.append('<span foreground="green">animation-speech ' + _("installed") + '</span>')
        if has_plasmoid:
            parts.append('<span foreground="green">' + _("Dictee plasmoid installed") + '</span>')
        if parts:
            self.lbl_anim_status.set_markup(" — ".join(parts))
        else:
            self.lbl_anim_status.set_markup("")

        # Speech warning
        needs_speech = mode in ("speech", "both")
        if needs_speech and not has_speech:
            self.lbl_anim_warn_speech.set_markup(
                '<span foreground="orange">'
                + _("animation-speech is not installed")
                + '</span>'
            )
            self.lbl_anim_warn_speech.show()
            self.btn_install_anim.show()
        else:
            self.lbl_anim_warn_speech.hide()
            self.btn_install_anim.hide()

        # Plasmoid warning
        needs_plasmoid = mode in ("plasmoid", "both")
        if needs_plasmoid and not has_plasmoid:
            self.lbl_anim_warn_plasmoid.set_markup(
                '<span foreground="orange">'
                + _("Dictee plasmoid is not installed")
                + '</span>'
            )
            self.lbl_anim_warn_plasmoid.show()
            self.btn_install_plasmoid.show()
        else:
            self.lbl_anim_warn_plasmoid.hide()
            self.btn_install_plasmoid.hide()

    def _on_install_plasmoid(self, _widget):
        """Install the Dictee plasmoid via kpackagetool6."""
        plasmoid_path = "/usr/share/dictee/dictee.plasmoid"
        if not os.path.isfile(plasmoid_path):
            dialog = Gtk.MessageDialog(
                transient_for=self,
                modal=True,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.OK,
                text=_("Installation error"),
            )
            dialog.format_secondary_text(
                _("File not found: {path}").format(path=plasmoid_path)
            )
            dialog.run()
            dialog.destroy()
            return

        try:
            # Essayer d'abord une mise a jour, sinon installer
            result = subprocess.run(
                ["kpackagetool6", "-t", "Plasma/Applet", "-u", plasmoid_path],
                capture_output=True, text=True,
            )
            if result.returncode != 0:
                result = subprocess.run(
                    ["kpackagetool6", "-t", "Plasma/Applet", "-i", plasmoid_path],
                    capture_output=True, text=True,
                )
            if result.returncode == 0:
                self._update_anim_availability()
            else:
                dialog = Gtk.MessageDialog(
                    transient_for=self,
                    modal=True,
                    message_type=Gtk.MessageType.ERROR,
                    buttons=Gtk.ButtonsType.OK,
                    text=_("Installation error"),
                )
                dialog.format_secondary_text(result.stderr.strip())
                dialog.run()
                dialog.destroy()
        except FileNotFoundError:
            dialog = Gtk.MessageDialog(
                transient_for=self,
                modal=True,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.OK,
                text=_("Installation error"),
            )
            dialog.format_secondary_text("kpackagetool6 " + _("not found"))
            dialog.run()
            dialog.destroy()

    def _on_install_animation(self, _widget):
        """Download and install the .deb from GitHub releases."""
        self.btn_install_anim.set_sensitive(False)
        self.btn_install_anim.set_label(_("Downloading…"))
        self.progress_anim.show()
        self.progress_anim.pulse()
        self._pulse_id = GLib.timeout_add(100, self._pulse_progress)

        thread = threading.Thread(target=self._download_and_install, daemon=True)
        thread.start()

    def _pulse_progress(self):
        self.progress_anim.pulse()
        return True

    @staticmethod
    def _is_debian_based():
        """Detect if the system uses dpkg (Debian/Ubuntu/Mint…)."""
        return shutil.which("dpkg") is not None

    def _download_and_install(self):
        """Thread: download .deb or .tar.gz via gh and install."""
        try:
            if not shutil.which("gh"):
                GLib.idle_add(
                    self._install_error,
                    _("The 'gh' tool (GitHub CLI) is required.\n"
                      "Install it: sudo apt install gh && gh auth login"),
                )
                return

            tmp_dir = tempfile.mkdtemp(prefix="dictee-setup-")

            if self._is_debian_based():
                result = subprocess.run(
                    ["gh", "release", "download", "--repo", ANIMATION_SPEECH_REPO,
                     "--pattern", "*.deb", "--dir", tmp_dir],
                    capture_output=True, text=True,
                )
                if result.returncode != 0:
                    GLib.idle_add(
                        self._install_error,
                        result.stderr.strip() or _("Download error (.deb)"),
                    )
                    return

                debs = [f for f in os.listdir(tmp_dir) if f.endswith(".deb")]
                if not debs:
                    GLib.idle_add(
                        self._install_error,
                        _("No .deb found in the release."),
                    )
                    return

                deb_path = os.path.join(tmp_dir, debs[0])
                GLib.idle_add(self._update_install_label, _("Installing…"))
                result = subprocess.run(
                    ["pkexec", "dpkg", "-i", deb_path],
                    capture_output=True, text=True,
                )
            else:
                result = subprocess.run(
                    ["gh", "release", "download", "--repo", ANIMATION_SPEECH_REPO,
                     "--pattern", "*.tar.gz", "--dir", tmp_dir],
                    capture_output=True, text=True,
                )
                if result.returncode != 0:
                    GLib.idle_add(
                        self._install_error,
                        result.stderr.strip() or _("Download error (.tar.gz)"),
                    )
                    return

                tarballs = [f for f in os.listdir(tmp_dir) if f.endswith(".tar.gz")]
                if not tarballs:
                    GLib.idle_add(
                        self._install_error,
                        _("No .tar.gz found in the release."),
                    )
                    return

                tarball_path = os.path.join(tmp_dir, tarballs[0])
                GLib.idle_add(self._update_install_label, _("Installing…"))
                result = subprocess.run(
                    ["pkexec", "tar", "xzf", tarball_path, "-C", "/usr/local"],
                    capture_output=True, text=True,
                )

            try:
                for f in os.listdir(tmp_dir):
                    os.remove(os.path.join(tmp_dir, f))
                os.rmdir(tmp_dir)
            except OSError:
                pass

            if result.returncode == 0:
                GLib.idle_add(self._install_success)
            else:
                err = result.stderr.strip() or _("Installation error.")
                GLib.idle_add(self._install_error, err)

        except Exception as e:
            GLib.idle_add(self._install_error, str(e))

    def _update_install_label(self, text):
        self.btn_install_anim.set_label(text)
        return False

    def _install_success(self):
        GLib.source_remove(self._pulse_id)
        self.progress_anim.hide()
        self._check_animation_speech()
        return False

    def _install_error(self, msg):
        GLib.source_remove(self._pulse_id)
        self.progress_anim.hide()
        self.btn_install_anim.set_label(_("Install animation-speech"))
        self.btn_install_anim.set_sensitive(True)
        dialog = Gtk.MessageDialog(
            transient_for=self,
            modal=True,
            message_type=Gtk.MessageType.ERROR,
            buttons=Gtk.ButtonsType.OK,
            text=_("Installation error"),
        )
        dialog.format_secondary_text(msg)
        dialog.run()
        dialog.destroy()
        return False

    # -- Apply --

    def _on_apply(self, _widget):
        translate = self.chk_translate.get_active()
        backend = "ollama" if self.radio_ollama.get_active() else "trans"
        lang_src = self.combo_src.get_active_id()
        lang_tgt = self.combo_tgt.get_active_id()

        clipboard = self.chk_clipboard.get_active()
        animation = self.combo_anim.get_active_id() or "speech"
        save_config(translate, backend, lang_src, lang_tgt, clipboard, animation)

        shortcut_msg = ""
        if self.captured_accel and self.de_type in ("kde", "gnome"):
            try:
                if self.de_type == "kde":
                    apply_kde_shortcut(self.captured_accel)
                    kde_accel = gtk_accel_to_kde(self.captured_accel)
                    shortcut_msg = "\n" + _("Shortcut applied: {key}").format(
                        key=kde_accel
                    )
                    shortcut_msg += "\n" + _(
                        "A re-login may be required to activate the shortcut."
                    )
                else:
                    apply_gnome_shortcut(self.captured_accel)
                    shortcut_msg = "\n" + _("Shortcut applied: {key}").format(
                        key=self.captured_accel
                    )
            except Exception as e:
                shortcut_msg = "\n" + _("Shortcut error: {err}").format(err=e)

        self._set_service("dictee", self.chk_daemon.get_active())
        self._set_service("dictee-tray", self.chk_tray.get_active())

        dialog = Gtk.MessageDialog(
            transient_for=self,
            modal=True,
            message_type=Gtk.MessageType.INFO,
            buttons=Gtk.ButtonsType.OK,
            text=_("Configuration saved"),
        )
        dialog.format_secondary_text(
            _("File: {path}").format(path=CONF_PATH) + shortcut_msg
        )
        dialog.run()
        dialog.destroy()
        self.close()


def main():
    win = DicteeSetupWindow()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
