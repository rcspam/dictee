#!/bin/bash
# dictee-plasmoid-level-daemon — Audio daemon for the Dictee plasmoid.
# Captures the microphone via parec, computes FFT bands via dictee-plasmoid-level-fft.
# Usage: dictee-level-daemon [N_BARS]
#        dictee-level-daemon stop

PID_FILE="/dev/shm/.dictee_level_v2_pid"
BANDS_FILE="/dev/shm/.dictee_audio_bands"
BARS_COUNT_FILE="/dev/shm/.dictee_level_bars"

cleanup() {
    # Kill parec if still running
    [ -n "$PAREC_PID" ] && kill "$PAREC_PID" 2>/dev/null
    [ -n "$FFT_PID" ] && kill "$FFT_PID" 2>/dev/null
    rm -f "$PID_FILE" "$BANDS_FILE" "$BARS_COUNT_FILE"
    exit 0
}

stop_existing() {
    if [ -f "$PID_FILE" ]; then
        local pid
        pid=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$pid" ]; then
            kill "$pid" 2>/dev/null
            sleep 0.2
            kill -9 "$pid" 2>/dev/null
        fi
    fi
    rm -f "$PID_FILE" "$BANDS_FILE" "$BARS_COUNT_FILE"
}

if [ "${1:-}" = "stop" ]; then
    stop_existing
    exit 0
fi

N_BARS="${1:-6}"
AUDIO_SOURCE="${2:-${DICTEE_AUDIO_SOURCE:-}}"

# Debug (same log as dictee)
_DBG_LOG="/tmp/dictee-debug-$(id -u).log"
_DICTEE_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/dictee.conf"
_DICTEE_DEBUG="${DICTEE_DEBUG:-false}"
[ -f "$_DICTEE_CONF" ] && { _d=$(grep '^DICTEE_DEBUG=' "$_DICTEE_CONF" 2>/dev/null | cut -d= -f2); [ -n "$_d" ] && _DICTEE_DEBUG="$_d"; }
_dbg() { [ "$_DICTEE_DEBUG" = "true" ] && printf '%s [level-daemon] %s\n' "$(date '+%H:%M:%S.%3N')" "$*" >> "$_DBG_LOG"; }

_dbg "start: bars=$N_BARS source=$AUDIO_SOURCE"

# Resolve app:name to application name (PipeWire IDs change after sleep)
if [[ "$AUDIO_SOURCE" == app:* ]]; then
    AUDIO_SOURCE="${AUDIO_SOURCE#app:}"
    _dbg "resolved app: → $AUDIO_SOURCE"
fi

# parec arguments for the audio source
PAREC_ARGS="--rate=16000 --channels=1 --format=s16le --latency-msec=40"
if [ -n "$AUDIO_SOURCE" ]; then
    # Check if it's a PulseAudio source (alsa_*) or an application
    case "$AUDIO_SOURCE" in
        alsa_*|*.monitor)
            # Source or monitor — use parec --device directly
            PAREC_ARGS="$PAREC_ARGS --device=$AUDIO_SOURCE"
            ;;
        *)
            # Application (Firefox, etc.) — find the sink's monitor
            _sink=$(LANG=C pactl list sink-inputs 2>/dev/null | awk -v app="$AUDIO_SOURCE" '
                /^\tSink:/ { sink=$NF }
                /application.name =/ && tolower($0) ~ tolower(app) { print sink; exit }
            ')
            _dbg "app source: sink_id=$_sink"
            if [ -n "$_sink" ]; then
                _sink_name=$(LANG=C pactl list sinks short 2>/dev/null | awk -v id="$_sink" '$1==id {print $2}')
                if [ -n "$_sink_name" ]; then
                    PAREC_ARGS="$PAREC_ARGS --device=${_sink_name}.monitor"
                    _dbg "app source: monitoring ${_sink_name}.monitor"
                else
                    _dbg "app source: WARNING — sink name not found for id=$_sink"
                fi
            else
                _dbg "app source: WARNING — app '$AUDIO_SOURCE' not found in pactl"
            fi
            ;;
    esac
fi

# Stop the previous daemon
stop_existing

# Write PID
echo $$ > "$PID_FILE"
echo "$N_BARS" > "$BARS_COUNT_FILE"

trap cleanup TERM INT HUP

# Initialize output
printf '%s' "$(printf '0 %.0s' $(seq 1 "$N_BARS"))" > "$BANDS_FILE"

# Check that parec is available
if ! command -v parec >/dev/null 2>&1; then
    echo "parec non trouvé (installer pulseaudio-utils)" >&2
    cleanup
fi

# Check that dictee-plasmoid-level-fft is available
if ! command -v dictee-plasmoid-level-fft >/dev/null 2>&1; then
    # Fallback: simple RMS mode without FFT
    parec $PAREC_ARGS 2>/dev/null | \
    while true; do
        # Read 2560 bytes (1280 samples x 2 bytes = 80ms at 16kHz)
        chunk=$(dd bs=2560 count=1 2>/dev/null | od -An -td2 -w2 | \
            awk -v n="$N_BARS" '
            BEGIN { for(i=0;i<n;i++) sum[i]=0; cnt=0 }
            { v=$1; if(v<0) v=-v; band=int(cnt*n/1280); sum[band]+=v; cnt++ }
            END {
                for(i=0;i<n;i++) {
                    avg = (cnt>0) ? sum[i]/(cnt/n)/32768.0 : 0
                    # Amplify for visibility
                    avg = avg * 8
                    if(avg > 1) avg = 1
                    printf "%.3f ", avg
                }
                printf "\n"
            }')
        printf '%s' "$chunk" > "$BANDS_FILE"
    done &
    PAREC_PID=$!
    wait $PAREC_PID
    cleanup
fi

# FFT mode: parec -> dictee-plasmoid-level-fft
parec $PAREC_ARGS 2>/dev/null | \
    dictee-plasmoid-level-fft "$N_BARS" "$BANDS_FILE" &
PAREC_PID=$!

wait $PAREC_PID
cleanup
