[Unit]
Description=Canary 1B v2 Transcription+Translation Daemon (ASR, GPU)
After=network.target
Conflicts=dictee.service dictee-vosk.service dictee-whisper.service

[Service]
Type=simple
EnvironmentFile=-%h/.config/dictee.conf
ExecStart=/usr/bin/transcribe-daemon --canary
ExecStartPost=/bin/bash -c 'echo idle > /dev/shm/.dictee_state'
ExecStopPost=/bin/bash -c 'for s in dictee dictee-vosk dictee-whisper dictee-canary; do systemctl --user is-active --quiet "$s.service" 2>/dev/null && exit 0; done; echo offline > /dev/shm/.dictee_state'
Restart=on-failure
RestartSec=5
Environment=XDG_RUNTIME_DIR=/run/user/%U
Environment=ORT_DYLIB_PATH=/usr/lib/dictee/libonnxruntime.so

[Install]
WantedBy=default.target
