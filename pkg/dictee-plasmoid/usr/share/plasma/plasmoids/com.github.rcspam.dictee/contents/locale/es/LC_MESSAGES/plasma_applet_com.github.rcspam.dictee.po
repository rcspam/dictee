#: ui/configGeneral.qml
msgid "General"
msgstr "General"

#: ui/configGeneral.qml
msgid "Polling interval (ms):"
msgstr "Intervalo de sondeo (ms):"

#: ui/configGeneral.qml
msgid "How often the widget checks if the daemon is running (in milliseconds)."
msgstr "Con qué frecuencia el widget comprueba si el daemon está en ejecución (en milisegundos)."

#: ui/configGeneral.qml
msgid "Show last transcription:"
msgstr "Mostrar última transcripción:"

#: ui/configGeneral.qml
msgid "Display the last transcribed text in the popup window."
msgstr "Mostrar el último texto transcrito en la ventana emergente."

#: ui/configGeneral.qml
msgid "Preview mode (test with mic):"
msgstr "Modo vista previa (prueba con micrófono):"

#: ui/configGeneral.qml
msgid "Microphone volume:"
msgstr "Volumen del micrófono:"

#: ui/configGeneral.qml
msgid "Adjust the microphone input volume (PipeWire/PulseAudio default source)."
msgstr "Ajustar el volumen de entrada del micrófono (fuente predeterminada PipeWire/PulseAudio)."

#: ui/configGeneral.qml
msgid "Noise floor:"
msgstr "Ruido de fondo:"

#: ui/configGeneral.qml
msgid "Calibrate"
msgstr "Calibrar"

#: ui/configGeneral.qml
msgid "Calibration done!"
msgstr "¡Calibración completada!"

#: ui/configGeneral.qml
msgid "Calibration failed"
msgstr "Calibración fallida"

#: ui/configGeneral.qml
msgid "Record 5 seconds of silence to calibrate the background noise level. This improves animation accuracy."
msgstr "Grabe 5 segundos de silencio para calibrar el nivel de ruido de fondo. Esto mejora la precisión de la animación."

#: ui/configGeneral.qml
msgid "Noise gate:"
msgstr "Noise gate:"

#: ui/configGeneral.qml
msgid "Audio levels below this threshold are zeroed. Increase to suppress background noise and get clean silence."
msgstr "Los niveles de audio por debajo de este umbral se ponen a cero. Aumente para suprimir el ruido de fondo y obtener un silencio limpio."

#: ui/configGeneral.qml
msgid "Envelope shape:"
msgstr "Forma de la envolvente:"

#: ui/configGeneral.qml
msgid "Flat"
msgstr "Plano"

#: ui/configGeneral.qml
msgid "Normal"
msgstr "Normal"

#: ui/configGeneral.qml
msgid "Controls the Hanning envelope shape. 0 = flat (uniform bars), 1 = normal, higher = more peaked at the center."
msgstr "Controla la forma de la envolvente de Hanning. 0 = plano (barras uniformes), 1 = normal, mayor = más pronunciado en el centro."

#: ui/configGeneral.qml
msgid "Envelope center:"
msgstr "Centro de la envolvente:"

#: ui/configGeneral.qml
msgid "Shift the envelope peak across the frequency range (80–4000 Hz). Useful with rainbow colors to emphasize different frequency bands."
msgstr "Desplazar el pico de la envolvente a lo largo del rango de frecuencias (80–4000 Hz). Útil con colores arcoíris para resaltar diferentes bandas de frecuencia."

