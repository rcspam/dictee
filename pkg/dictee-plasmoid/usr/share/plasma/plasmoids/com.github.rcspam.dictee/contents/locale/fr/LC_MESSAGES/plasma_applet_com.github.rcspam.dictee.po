msgstr "Dictée non configuré — lancez dictee-setup"

msgid "Daemon stopped"
msgstr "Daemon arrêté"

msgid "Daemon active"
msgstr "Daemon actif"

msgid "Switching backend…"
msgstr "Changement de backend…"

